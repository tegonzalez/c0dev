#!/bin/sh

# Intended to be sourced (POSIX): `. ./activate`
# Works in sh and bash; avoids bash arrays and `source`.

prepend_path() {
	p=$1
	[ -n "$p" ] || return 0
	[ -d "$p" ] || return 0
	case ":${PATH}:" in
	*:"$p":*)
		;;
	*)
		if [ -n "${PATH}" ]; then
			PATH="$p:$PATH"
		else
			PATH="$p"
		fi
		;;
	esac
}

resolve_path() {
	p=$1
	[ -n "$p" ] || return 1
	realpath "$p" 2>/dev/null
}

script_path=$0
if [ -n "${BASH_SOURCE:-}" ]; then
	script_path=${BASH_SOURCE}
fi
case "$script_path" in
sh|-sh|dash|-dash|*/sh|*/dash)
	# POSIX sh does not expose the path of a sourced file.
	# ~/.profile sources this file from ~/bin/activate.
	script_path=${HOME}/bin/activate
	;;
esac

script_dir=$(resolve_path "$(dirname -- "$script_path")")
root_dir=$(resolve_path "$script_dir/..")

prepend_path "/usr/local/bun-node-fallback-bin"

if [ -n "${TOOLS_PREFIX:-}" ]; then
	prepend_path "$TOOLS_PREFIX/.cargo/bin"
	prepend_path "$TOOLS_PREFIX/.local/bin"
	export RUSTUP_HOME="$TOOLS_PREFIX/.rustup"
	export CARGO_HOME="${HOME}/.cache/cargo"
	export UV_CACHE_DIR="${HOME}/.cache/uv"
	export XDG_CACHE_HOME="${HOME}/.cache"
	export RUSTUP_NO_UPDATE=1
	if [ -d "$TOOLS_PREFIX/.rustup" ]; then
		ln -sfn "$TOOLS_PREFIX/.rustup" "${HOME}/.rustup"
	fi
else
	prepend_path "$(resolve_path "$root_dir/.cargo/bin")"
	prepend_path "$(resolve_path "$root_dir/.local/bin")"
fi

prepend_path "$(resolve_path "$root_dir/bin")"

export PATH
