#!/bin/bash

# Service management script for c0-dev environment
# Usage: ./c0 [start|stop|restart|logs|sh|root|status|cp-term|build [-f]|clean|help]

set -e

# =============================================================================
# Colors for output
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
WHITE='\033[0;37m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# =============================================================================
# Preconditions (fail-fast)
# =============================================================================

C0ROOT="$(realpath "$(dirname "$0")/..")"

# Required files - exit non-zero if any are missing
REQUIRED_FILES=(
    "$C0ROOT/docker/docker-compose.public.yaml"
    "$C0ROOT/docker/volumes-folders.yaml"
    "$C0ROOT/docker/volumes-files.yaml"
    "$C0ROOT/docker/Dockerfile"
)

for f in "${REQUIRED_FILES[@]}"; do
    if [[ ! -f "$f" ]]; then
        echo "error: required file missing: $f" >&2
        exit 1
    fi
done

# Detect if running inside container
if [[ -f /.dockerenv ]] || grep -q docker /proc/1/cgroup 2>/dev/null; then
    IN_CONTAINER=true
else
    IN_CONTAINER=false
fi

# =============================================================================
# Mode and project naming
# =============================================================================

# =============================================================================
# Web port allocation
# =============================================================================

# Host port range used to map guest:3000 -> host:<port>
C0DEV_WEB_PORT_MIN=3000
C0DEV_WEB_PORT_MAX=4000

# C0_MODE validation: only "" (prod) or "dev" allowed
if [[ -n "$C0_MODE" && "$C0_MODE" != "dev" ]]; then
    echo "error: C0_MODE must be empty (production) or 'dev', got: '$C0_MODE'" >&2
    exit 1
fi

# Short hash function (first 8 chars of sha256)
short_hash() {
    echo -n "$1" | shasum -a 256 | cut -c1-8
}

# Project naming based on mode
if [[ "$C0_MODE" == "dev" ]]; then
    PROJECT_NAME="c0dev-dev-$(short_hash "${C0ROOT}:dev")"
    SHARED_TOOLS_VOLUME="c0dev-tools-shared-dev"
else
    PROJECT_NAME="c0dev-$(short_hash "$C0ROOT")"
    SHARED_TOOLS_VOLUME="c0dev-tools-shared"
fi

# Dockerfile hash for tools prefix
DOCKERFILE_HASH="$(shasum -a 256 "$C0ROOT/docker/Dockerfile" | cut -c1-64)"
TOOLS_PREFIX="/tools/opt/$DOCKERFILE_HASH"

# =============================================================================
# Compose file paths
# =============================================================================

COMPOSE_PUBLIC_FILE="$C0ROOT/docker/docker-compose.public.yaml"
VOLUMES_FOLDERS_FILE="$C0ROOT/docker/volumes-folders.yaml"
VOLUMES_FILES_FILE="$C0ROOT/docker/volumes-files.yaml"
MAIN_SERVICE="c0-dev"
CONTAINER_DEV_HOME="/home/dev"

# =============================================================================
# Helper: docker-compose wrapper with project isolation
# =============================================================================

dc() {
    export SHARED_TOOLS_VOLUME
    export TOOLS_PREFIX
    export DOCKERFILE_HASH
    export C0DEV_HOSTNAME="$PROJECT_NAME"
    docker compose \
        -p "$PROJECT_NAME" \
        -f "$VOLUMES_FOLDERS_FILE" \
        -f "$VOLUMES_FILES_FILE" \
        -f "$COMPOSE_PUBLIC_FILE" \
        "$@"
}

# =============================================================================
# Helper functions
# =============================================================================

get_mapped_web_port_from_container() {
    local container_id="$1"
    docker inspect -f '{{with (index .NetworkSettings.Ports "3000/tcp")}}{{(index . 0).HostPort}}{{end}}' "$container_id" 2>/dev/null || true
}

get_current_web_port() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local container_id
    container_id="$(dc ps -aq "$MAIN_SERVICE" 2>/dev/null | head -n 1 || true)"
    if [[ -n "$container_id" ]]; then
        local mapped
        mapped="$(get_mapped_web_port_from_container "$container_id")"
        if [[ -n "$mapped" ]]; then
            echo "$mapped"
            return 0
        fi
    fi

    if [[ -n "${C0DEV_WEB_PORT:-}" ]]; then
        echo "$C0DEV_WEB_PORT"
        return 0
    fi
}

ensure_web_port() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if [[ -n "${C0DEV_WEB_PORT:-}" ]]; then
        return 0
    fi

    local start="$C0DEV_WEB_PORT_MIN"
    local end="$C0DEV_WEB_PORT_MAX"
    local ports_cmd="$C0ROOT/bin/list-listening-ports"
    if [[ ! -x "$ports_cmd" ]]; then
        echo "error: missing required helper: $ports_cmd" >&2
        return 1
    fi

    # Finds the first integer >= start that is not present in the provided set.
    # Signature: first_gap_port <start> [ports...]
    # Assumes the list is sorted ascending (as produced by bin/list-listening-ports).
    first_gap_port() {
        local start="$1"
        shift

        local candidate="$start"
        local port
        for port in "$@"; do
            case "$port" in
                ''|*[!0-9]*) continue ;;
            esac

            if [[ "$port" -lt "$candidate" ]]; then
                continue
            fi
            if [[ "$port" -eq "$candidate" ]]; then
                candidate=$((candidate + 1))
                continue
            fi

            # port > candidate means candidate is a gap
            echo "$candidate"
            return 0
        done

        echo "$candidate"
        return 0
    }

    local ports
    if ! ports="$("$ports_cmd" "$start" "$end")"; then
        return 1
    fi

    local next
    local -a port_list=()
    if [[ -n "$ports" ]]; then
        local line
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            port_list+=("$line")
        done <<<"$ports"
    fi

    next="$(first_gap_port "$start" "${port_list[@]}")"

    if [[ "$next" -gt "$end" ]]; then
        echo "error: no ports left in range ${start}-${end}" >&2
        return 1
    fi

    C0DEV_WEB_PORT="$next"
    export C0DEV_WEB_PORT
}

print_web_port_mapping() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local port
    port="$(get_current_web_port || true)"
    if [[ -n "$port" ]]; then
        echo -e "🌐 Port: ${YELLOW}host:${port}${NC} -> ${YELLOW}guest:3000${NC}"
    fi
}

# Resolve a host path from a docker volume mapping into an absolute path.
resolve_volume_host_path() {
    local host_path="$1"
    local abs_host_path="$host_path"

    if [[ "$abs_host_path" == "~" ]]; then
        abs_host_path="$HOME"
    elif [[ "$abs_host_path" == "~/"* ]]; then
        abs_host_path="$HOME/${abs_host_path:2}"
    fi

    if [[ "$abs_host_path" =~ ^\.\. ]]; then
        abs_host_path="$C0ROOT/${abs_host_path#../}"
    elif [[ "$abs_host_path" =~ ^\. ]]; then
        abs_host_path="$C0ROOT/docker/${abs_host_path#./}"
    fi

    echo "$abs_host_path"
}

# Check if path looks like a docker volume name (not a host path)
is_docker_volume() {
    local path="$1"
    # Docker volumes don't start with /, ~, or .
    [[ ! "$path" =~ ^[/~.] ]]
}

# Convert absolute path to display path relative to C0ROOT
to_display_path() {
    local abs_path="$1"
    if [[ "$abs_path" == "$C0ROOT"/* ]]; then
        echo ".${abs_path#$C0ROOT}"
    elif [[ "$abs_path" == "$HOME"/* ]]; then
        echo "~${abs_path#$HOME}"
    else
        echo "$abs_path"
    fi
}

# Parse volumes-folders.yaml for folder mappings
# Calls callback: callback_func "$abs_host_path" "$container_path" "folder" "$display_host_path" "$ro"
parse_folder_mappings() {
    local callback_func="$1"
    local in_folders=false

    while IFS= read -r line; do
        if [[ "$line" =~ ^x-volume-folders:[[:space:]]*\&folders ]]; then
            in_folders=true
            continue
        fi

        if [[ "$in_folders" == true && "$line" =~ ^[^[:space:]#] ]]; then
            in_folders=false
        fi

        if [[ "$in_folders" == true && "$line" =~ ^[[:space:]]+-[[:space:]]*(.+)$ ]]; then
            local volume_line="${BASH_REMATCH[1]}"
            volume_line=$(echo "$volume_line" | sed 's/#.*//')
            volume_line=$(echo "$volume_line" | xargs)
            [[ -z "$volume_line" ]] && continue

            local host_path container_path ro
            # Parse host:container or host:container:ro
            IFS=':' read -r host_path container_path ro <<< "$volume_line"

            if is_docker_volume "$host_path"; then
                # Docker volume, not a host path
                "$callback_func" "" "$container_path" "docker-volume" "$host_path" "$ro"
            else
                local abs_host_path display_path
                abs_host_path="$(resolve_volume_host_path "$host_path")"
                display_path="$(to_display_path "$abs_host_path")"
                "$callback_func" "$abs_host_path" "$container_path" "host-dir" "$display_path" "$ro"
            fi
        fi
    done < "$VOLUMES_FOLDERS_FILE"
}

# Parse volumes-files.yaml for file mappings
# Calls callback: callback_func "$abs_host_path" "$container_path" "file" "$display_host_path" "$ro"
parse_file_mappings() {
    local callback_func="$1"
    local in_files=false

    while IFS= read -r line; do
        if [[ "$line" =~ ^x-volume-files:[[:space:]]*\&files ]]; then
            in_files=true
            continue
        fi

        if [[ "$in_files" == true && "$line" =~ ^[^[:space:]#] ]]; then
            break
        fi

        if [[ "$in_files" == true && "$line" =~ ^[[:space:]]+-[[:space:]]*(.+)$ ]]; then
            local volume_line="${BASH_REMATCH[1]}"
            volume_line=$(echo "$volume_line" | sed 's/#.*//')
            volume_line=$(echo "$volume_line" | xargs)
            [[ -z "$volume_line" ]] && continue

            local host_path container_path ro
            IFS=':' read -r host_path container_path ro <<< "$volume_line"

            if is_docker_volume "$host_path"; then
                "$callback_func" "" "$container_path" "docker-volume" "$host_path" "$ro"
            else
                local abs_host_path display_path
                abs_host_path="$(resolve_volume_host_path "$host_path")"
                display_path="$(to_display_path "$abs_host_path")"
                "$callback_func" "$abs_host_path" "$container_path" "host-file" "$display_path" "$ro"
            fi
        fi
    done < "$VOLUMES_FILES_FILE"
}

# Validate all host paths exist and are correct type
# Returns 0 if valid, 1 if errors; prints errors to stderr
validate_host_paths() {
    local errors=()
    local missing_dirs=()
    local missing_files=()

    _validate_folder_callback() {
    local abs_host_path="$1"
    local container_path="$2"
        local type="$3"
        local display_path="$4"

        if [[ "$type" == "host-dir" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                errors+=("missing: $display_path")
                missing_dirs+=("$abs_host_path")
            elif [[ ! -d "$abs_host_path" ]]; then
                errors+=("not a directory (remove file first): $display_path")
            fi
        fi
    }

    _validate_file_callback() {
        local abs_host_path="$1"
        local container_path="$2"
        local type="$3"
        local display_path="$4"

        if [[ "$type" == "host-file" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                errors+=("missing: $display_path")
                missing_files+=("$abs_host_path")
            elif [[ ! -f "$abs_host_path" ]]; then
                errors+=("not a file: $display_path")
            fi
        fi
    }

    parse_folder_mappings _validate_folder_callback
    parse_file_mappings _validate_file_callback

    if [[ ${#errors[@]} -gt 0 ]]; then
        echo "error: host path validation failed:" >&2
        for err in "${errors[@]}"; do
            echo "  - $err" >&2
        done
        # Suggest fix for missing paths
        if [[ ${#missing_dirs[@]} -gt 0 || ${#missing_files[@]} -gt 0 ]]; then
            echo "" >&2
            echo "create missing paths:" >&2
            for d in "${missing_dirs[@]}"; do
                echo "  mkdir -p \"$d\"" >&2
            done
            for f in "${missing_files[@]}"; do
                echo "  touch \"$f\"" >&2
            done
        fi
        return 1
    fi
    return 0
}

# Check if shared tools volume exists and is valid for current Dockerfile hash
tools_volume_valid() {
    # Check if volume exists
    if ! docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
        return 1
    fi

    # Check if completeness marker exists
    docker run --rm -v "$SHARED_TOOLS_VOLUME:/tools:ro" alpine \
        test -f "/tools/opt/$DOCKERFILE_HASH/.c0dev-complete" 2>/dev/null
}

# Get project relative path for shell navigation
get_project_path() {
    local current_dir="$(realpath "$(pwd)")"
    local projects_dir="$C0ROOT/projects"

    if [[ "$current_dir" == "$projects_dir" ]]; then
        echo "."
    elif [[ "$current_dir" == "$projects_dir"* ]]; then
        echo "${current_dir#$projects_dir/}"
    else
        echo ""
    fi
}

# Host-only guard
require_host() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        echo "error: '$1' must be run from host, not inside container" >&2
        exit 1
    fi
}

# =============================================================================
# Tools volume and runtime identity helpers (Phase 1)
# =============================================================================

# Check if tools volume exists
tools_volume_exists() {
    docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null
}

# Execute shell command in tools volume using alpine container
tools_volume_sh() {
    docker run --rm -v "$SHARED_TOOLS_VOLUME:/tools" alpine sh -c "$*"
}

# List running container IDs using the shared tools volume
list_running_container_ids_using_tools_volume() {
    docker ps -q --filter "volume=$SHARED_TOOLS_VOLUME" 2>/dev/null || true
}

# Get tools hash label from a container
get_tools_hash_label() {
    local container_id="$1"
    docker inspect "$container_id" --format '{{ index .Config.Labels "c0dev.tools_hash" }}' 2>/dev/null || true
}

# Get unique active hashes from running containers
get_active_hashes() {
    local -a hashes=()
    local container_id hash

    while IFS= read -r container_id; do
        [[ -z "$container_id" ]] && continue
        hash="$(get_tools_hash_label "$container_id")"
        [[ -n "$hash" ]] && hashes+=("$hash")
    done < <(list_running_container_ids_using_tools_volume)

    # Return unique hashes (sorted)
    if [[ ${#hashes[@]} -gt 0 ]]; then
        printf '%s\n' "${hashes[@]}" | sort -u
    fi
}

# =============================================================================
# Pin management helpers (Phase 2)
# =============================================================================

# Compute folder identity (sha256 of C0ROOT:C0_MODE)
compute_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 1
    fi
    echo -n "${C0ROOT}:${C0_MODE}" | shasum -a 256 | cut -c1-64
}

# Get pin path for a folder ID
pin_path_for_folder_id() {
    local folder_id="$1"
    echo "/tools/pins/${folder_id}.pin"
}

# Read pin for current folder (returns hash or empty)
read_pin_for_folder_id() {
    local folder_id="$1"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    if ! tools_volume_exists; then
        return 0
    fi

    local content
    content="$(tools_volume_sh "cat '$pin_path' 2>/dev/null || true")"
    if [[ -n "$content" ]]; then
        echo "$content" | grep '^hash=' | cut -d= -f2
    fi
}

# Write pin for current folder
write_pin_for_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local folder_id="$1"
    local hash="$2"
    local c0root="$3"
    local mode="$4"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    local updated_at
    updated_at="$(date +%s)"

    tools_volume_sh "
        mkdir -p /tools/pins
        cat > '$pin_path' <<EOF
hash=$hash
c0root=$c0root
mode=$mode
updated_at=$updated_at
EOF
    " >/dev/null
}

# Delete pin for current folder
delete_pin_for_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local folder_id="$1"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    if ! tools_volume_exists; then
        return 0
    fi

    tools_volume_sh "rm -f '$pin_path'" >/dev/null 2>&1 || true
}

# List all pins (outputs: folder_id hash c0root on each line)
list_all_pins() {
    if ! tools_volume_exists; then
        return 0
    fi

    local pins_list
    pins_list="$(tools_volume_sh "ls /tools/pins/*.pin 2>/dev/null || true")"
    [[ -z "$pins_list" ]] && return 0

    local pin_file
    while IFS= read -r pin_file; do
        [[ -z "$pin_file" ]] && continue
        local folder_id
        folder_id="$(basename "$pin_file" .pin)"
        local content
        content="$(tools_volume_sh "cat '$pin_file' 2>/dev/null || true")"
        if [[ -n "$content" ]]; then
            local hash c0root
            hash="$(echo "$content" | grep '^hash=' | cut -d= -f2)"
            c0root="$(echo "$content" | grep '^c0root=' | cut -d= -f2-)"
            if [[ -n "$hash" && -n "$c0root" ]]; then
                echo "$folder_id $hash $c0root"
            fi
        fi
    done <<<"$pins_list"
}

# =============================================================================
# Garbage collection helpers (Phase 5)
# =============================================================================

# Clean up orphan pins (pins for folders deleted from disk)
cleanup_orphan_pins() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    local pin_info folder_id hash c0root
    while read -r folder_id hash c0root; do
        [[ -z "$folder_id" ]] && continue
        if [[ ! -d "$c0root" ]]; then
            # Folder deleted, remove orphan pin
            delete_pin_for_folder_id "$folder_id"
        fi
    done < <(list_all_pins)
}

# Get all pinned hashes (from valid pins only)
get_pinned_hashes() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    local -a hashes=()
    local pin_info folder_id hash c0root
    while read -r folder_id hash c0root; do
        [[ -z "$folder_id" ]] && continue
        if [[ -d "$c0root" ]]; then
            hashes+=("$hash")
        fi
    done < <(list_all_pins)

    # Return unique hashes (sorted)
    if [[ ${#hashes[@]} -gt 0 ]]; then
        printf '%s\n' "${hashes[@]}" | sort -u
    fi
}

# Garbage collect unprotected hash directories
gc_tools_hashes() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    # First, clean up orphan pins
    cleanup_orphan_pins

    # Compute protected set: active ∪ pinned
    local active_hashes pinned_hashes
    active_hashes="$(get_active_hashes)"
    pinned_hashes="$(get_pinned_hashes)"

    local -a protected=()
    if [[ -n "$active_hashes" ]]; then
        while IFS= read -r hash; do
            [[ -n "$hash" ]] && protected+=("$hash")
        done <<<"$active_hashes"
    fi
    if [[ -n "$pinned_hashes" ]]; then
        while IFS= read -r hash; do
            [[ -n "$hash" ]] && protected+=("$hash")
        done <<<"$pinned_hashes"
    fi

    # Get unique protected hashes
    local protected_set
    if [[ ${#protected[@]} -gt 0 ]]; then
        protected_set="$(printf '%s\n' "${protected[@]}" | sort -u)"
    fi

    # List existing hash dirs in /tools/opt
    local hash_dirs
    hash_dirs="$(tools_volume_sh "ls -1 /tools/opt 2>/dev/null || true")"
    [[ -z "$hash_dirs" ]] && return 0

    local hash
    while IFS= read -r hash; do
        [[ -z "$hash" ]] && continue

        # Skip if not 64-hex hash
        if [[ ! "$hash" =~ ^[0-9a-f]{64}$ ]]; then
            continue
        fi

        # Skip if no completeness marker (weird/partial dir)
        if ! tools_volume_sh "test -f '/tools/opt/$hash/.c0dev-complete'" 2>/dev/null; then
            continue
        fi

        # Skip if protected (active or pinned)
        if [[ -n "$protected_set" ]] && echo "$protected_set" | grep -qx "$hash"; then
            continue
        fi

        # Not protected - remove it
        if tools_volume_sh "rm -rf '/tools/opt/$hash'" 2>/dev/null; then
            echo -e "  🗑️  GC: ${YELLOW}${hash:0:12}...${NC}"
        fi
    done <<<"$hash_dirs"
}

# =============================================================================
# Build: tools volume (transactional) with staged rebuild support (Phase 4)
# =============================================================================

# Promote staged .next build to final location (if safe)
maybe_promote_staged_next() {
    local hash="$1"
    local VOL="$SHARED_TOOLS_VOLUME"

    if ! tools_volume_exists; then
        return 0
    fi

    # Check if .next staging exists
    if ! tools_volume_sh "test -d '/tools/tmp/$hash.next'" 2>/dev/null; then
        return 0
    fi

    # Check if hash is still active
    local active_hashes
    active_hashes="$(get_active_hashes)"
    if echo "$active_hashes" | grep -qx "$hash"; then
        # Still active, cannot promote yet
        return 0
    fi

    # Safe to promote
    echo -e "  📥 Promoting staged build..."
    if tools_volume_sh "
        set -e
        mkdir -p /tools/opt
        rm -rf '/tools/opt/$hash.old'
        if [ -d '/tools/opt/$hash' ]; then
            mv '/tools/opt/$hash' '/tools/opt/$hash.old'
        fi
        mv '/tools/tmp/$hash.next' '/tools/opt/$hash'
        rm -rf '/tools/opt/$hash.old'
    " 2>/dev/null; then
        echo -e "  ✅ Promoted: ${GREEN}/tools/opt/${hash:0:12}...${NC}"
    else
        echo "warning: failed to promote staged build" >&2
    fi
}

build_tools_volume() {
    local force="${1:-false}"
    local nocache="${2:-}"
    local H="$DOCKERFILE_HASH"
    local VOL="$SHARED_TOOLS_VOLUME"
    local TAG="c0dev-tools-builder:$H"

    # Try to promote any staged .next build for this hash (Phase 4)
    maybe_promote_staged_next "$H"

    # Check if rebuild needed
    if [[ "$force" != "true" ]] && tools_volume_valid; then
        echo -e "📦 Tools: ${GREEN}valid${NC}"
        return 0
    fi

    echo -e "📦 Tools: building..."

    # Clean up any leftover containers from previous/interrupted builds
    docker rm -f "$MAIN_SERVICE-tools-build" 2>/dev/null || true
    docker rm -f "$MAIN_SERVICE-tools" 2>/dev/null || true

    # Cleanup function for interrupts
    _build_cleanup() {
        echo -e "\n${RED}build interrupted${NC}" >&2
        docker rmi "$TAG" 2>/dev/null || true
        # Remove partial temp dir
        docker run --rm -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        exit 130
    }
    trap _build_cleanup INT TERM

    # 1) Ensure volume exists
    docker volume create "$VOL" >/dev/null

    # 2) Build tools image
    echo -e "  🔧 Building tools-builder stage..."
    if ! docker build $nocache --target tools-builder -t "$TAG" "$C0ROOT/docker"; then
        trap - INT TERM
        return 1
    fi

    # 3) Stream tarball from tools image into volume temp dir
    echo -e "  📤 Extracting to temp..."
    if ! (docker run --rm "$TAG" sh -lc 'tar -C /home/dev -cf - .cargo .rustup .local' | \
        docker run --rm -i -v "$VOL:/tools" alpine sh -c "
            set -e
            rm -rf '/tools/tmp/$H.partial'
            mkdir -p '/tools/tmp/$H.partial'
            tar -C '/tools/tmp/$H.partial' -xf -
        "); then
        trap - INT TERM
        docker run --rm -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        return 1
    fi

    # 4) Write completeness marker
    echo -e "  ✓ Marking complete..."
    if ! docker run --rm -v "$VOL:/tools" alpine touch "/tools/tmp/$H.partial/.c0dev-complete"; then
        trap - INT TERM
        docker run --rm -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        return 1
    fi

    # 5) Check if hash is active - if so, stage instead of promoting (Phase 4)
    local active_hashes
    active_hashes="$(get_active_hashes)"
    local is_active=false
    if echo "$active_hashes" | grep -qx "$H"; then
        is_active=true
    fi

    if [[ "$is_active" == "true" && "$force" == "true" ]]; then
        # Stage to .next instead of promoting
        echo -e "  📦 Staging (hash is active)..."
        if ! docker run --rm -v "$VOL:/tools" alpine sh -c "
            set -e
            mkdir -p /tools/tmp
            rm -rf '/tools/tmp/$H.next.old'
            if [ -d '/tools/tmp/$H.next' ]; then
                mv '/tools/tmp/$H.next' '/tools/tmp/$H.next.old'
            fi
            mv '/tools/tmp/$H.partial' '/tools/tmp/$H.next'
            rm -rf '/tools/tmp/$H.next.old'
        "; then
            trap - INT TERM
            return 1
        fi
        echo -e "  ⏸️  Staged: will promote after instances stop"
    else
        # Safe to promote directly
        echo -e "  📥 Promoting..."
        if ! docker run --rm -v "$VOL:/tools" alpine sh -c "
            set -e
            mkdir -p /tools/opt
            rm -rf '/tools/opt/$H.old'
            if [ -d '/tools/opt/$H' ]; then
                mv '/tools/opt/$H' '/tools/opt/$H.old'
            fi
            mv '/tools/tmp/$H.partial' '/tools/opt/$H'
            rm -rf '/tools/opt/$H.old'
            rm -rf '/tools/tmp/$H.partial'
        "; then
            trap - INT TERM
            return 1
        fi
    fi

    # 6) Post-verify
    if ! docker run --rm -v "$VOL:/tools:ro" alpine test -f "/tools/opt/$H/.c0dev-complete"; then
        echo "error: tools build failed - completeness marker missing" >&2
        trap - INT TERM
        return 1
    fi

    # Cleanup builder image
    docker rmi "$TAG" >/dev/null 2>&1 || true

    # Clear trap
    trap - INT TERM

    echo -e "  ✅ Tools: ${GREEN}complete${NC}"
}

# =============================================================================
# Commands
# =============================================================================

cmd_start() {
    require_host "start"

    ensure_web_port

    # Validate host paths
    if ! validate_host_paths; then
        echo "error: fix missing paths before starting" >&2
            exit 1
        fi

    # Check tools volume
    if ! tools_volume_valid; then
        echo "error: tools volume invalid or missing - run 'c0 build' first" >&2
            exit 1
        fi

    echo -e "🚀 Starting ${CYAN}$PROJECT_NAME${NC}..."
    if ! dc up -d; then
        echo "error: failed to start containers (port may already be in use)" >&2
        echo "hint: retry with a different port, e.g. C0DEV_WEB_PORT=3001 c0 start" >&2
        exit 1
    fi
    print_web_port_mapping
    echo -e "✅ Started: ${GREEN}$MAIN_SERVICE${NC}"
}

cmd_stop() {
    require_host "stop"
    echo -e "🛑 Stopping ${CYAN}$PROJECT_NAME${NC}..."
    dc down
    echo -e "✅ Stopped"
}

cmd_restart() {
    require_host "restart"
    ensure_web_port
    echo -e "🔄 Restarting ${CYAN}$PROJECT_NAME${NC}..."
    dc down

    # Validate before restart
    if ! validate_host_paths; then
        echo "error: fix missing paths before starting" >&2
            exit 1
        fi
    if ! tools_volume_valid; then
        echo "error: tools volume invalid - run 'c0 build' first" >&2
            exit 1
        fi

    if ! dc up -d; then
        echo "error: failed to restart containers (port may already be in use)" >&2
        echo "hint: retry with a different port, e.g. C0DEV_WEB_PORT=3001 c0 start" >&2
        exit 1
    fi
    print_web_port_mapping
    echo -e "✅ Restarted: ${GREEN}$MAIN_SERVICE${NC}"
}

cmd_logs() {
    require_host "logs"
    local service="${1:-$MAIN_SERVICE}"
    dc logs -f "$service"
}

cmd_status() {
    require_host "status"

    if [[ -n "$C0_MODE" ]]; then
        echo -e "${BOLD}mode:${NC} $C0_MODE"
    fi
    echo ""

    # Port mapping (if container exists)
    echo -e "${BOLD}ports:${NC}"
    local mapped_port
    mapped_port="$(get_current_web_port || true)"
    if [[ -n "$mapped_port" ]]; then
        echo -e "  🌐 ${YELLOW}host:${mapped_port}${NC} -> ${YELLOW}guest:3000${NC}"
    else
        echo -e "  ${YELLOW}(none)${NC}"
    fi
    echo ""

    # Container status
    echo -e "${BOLD}running containers:${NC}"
    local container_info
    container_info=$(dc ps --format "{{.Name}}: {{.State}}" 2>/dev/null | head -1)
    if [[ -n "$container_info" ]]; then
        if [[ "$container_info" =~ running ]]; then
            echo -e "  ${GREEN}$container_info${NC}"
        elif [[ "$container_info" =~ exited ]]; then
            echo -e "  ${RED}$container_info${NC}"
        else
            echo -e "  ${YELLOW}$container_info${NC}"
        fi
    else
        echo -e "  ${YELLOW}(none)${NC}"
    fi
    echo ""

    # Volume mappings
    echo -e "${BOLD}volumes:${NC}"
    _status_mapping() {
        local abs_host_path="$1"
        local container_path="$2"
        local type="$3"
        local display_path="$4"
        local ro="$5"

        local ro_flag=""
        [[ "$ro" == "ro" ]] && ro_flag=" ${MAGENTA}[ro]${NC}"

        local status="ok"
        if [[ "$type" == "host-dir" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                status="MISSING"
            elif [[ ! -d "$abs_host_path" ]]; then
                status="NOT-DIR"
            fi
        elif [[ "$type" == "host-file" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                status="MISSING"
            elif [[ ! -f "$abs_host_path" ]]; then
                status="NOT-FILE"
            fi
        fi

        local type_color="$BLUE"
        [[ "$type" == "docker-volume" ]] && type_color="$MAGENTA"

        if [[ "$status" == "ok" ]]; then
            echo -e "  ${GREEN}✓${NC} ${type_color}[$type]${NC} ${CYAN}$display_path${NC} -> ${YELLOW}$container_path${NC}$ro_flag"
        else
            echo -e "  ${RED}✗${NC} ${type_color}[$type]${NC} ${CYAN}$display_path${NC} -> ${YELLOW}$container_path${NC} ${RED}($status)${NC}"
        fi
    }

    parse_folder_mappings _status_mapping
    parse_file_mappings _status_mapping
    echo ""

    # Shared tools volume
    echo -e "${BOLD}tools:${NC}"
    if tools_volume_valid; then
        echo -e "  ${GREEN}✓${NC} ${CYAN}$SHARED_TOOLS_VOLUME${NC} (${YELLOW}${DOCKERFILE_HASH:0:12}...${NC})"
    else
        echo -e "  ${RED}✗${NC} ${CYAN}$SHARED_TOOLS_VOLUME${NC} (${YELLOW}${DOCKERFILE_HASH:0:12}...${NC}) - run 'c0 build'"
    fi
}

cmd_sh() {
    require_host "sh"
    local project_path
    project_path=$(get_project_path)
    if [[ -n "$project_path" ]]; then
        print_web_port_mapping
        echo -e "🐚 Shell: ${CYAN}$MAIN_SERVICE${NC} (dev) @ ${YELLOW}projects/$project_path${NC}"
        dc exec -u 1000 "$MAIN_SERVICE" bash -c "cd $CONTAINER_DEV_HOME/projects/$project_path && exec bash -l"
    else
        print_web_port_mapping
        echo -e "🐚 Shell: ${CYAN}$MAIN_SERVICE${NC} (dev)"
        dc exec -u 1000 "$MAIN_SERVICE" bash -l
    fi
}

cmd_root() {
    require_host "root"
    local project_path
    project_path=$(get_project_path)
    if [[ -n "$project_path" ]]; then
        print_web_port_mapping
        echo -e "🔧 Shell: ${CYAN}$MAIN_SERVICE${NC} (${RED}root${NC}) @ ${YELLOW}projects/$project_path${NC}"
        dc exec -u 0 "$MAIN_SERVICE" bash -c "cd $CONTAINER_DEV_HOME/projects/$project_path && exec bash"
    else
        print_web_port_mapping
        echo -e "🔧 Shell: ${CYAN}$MAIN_SERVICE${NC} (${RED}root${NC})"
        dc exec -u 0 "$MAIN_SERVICE" bash
    fi
}

cmd_cp_term() {
    require_host "cp-term"
    local container_name
    container_name=$(dc ps -q "$MAIN_SERVICE" 2>/dev/null)
    if [[ -z "$container_name" ]]; then
        echo "error: container not running" >&2
            exit 1
        fi
        for term in xterm-256color $TERM; do
        infocmp -xa "$term" | docker exec -u 0 -i "$container_name" tic -x -o /usr/share/terminfo/ -
        echo -e "✅ Copied: ${CYAN}$term${NC}"
    done
}

cmd_build() {
    require_host "build"

    local force=false
    local nocache=""
    if [[ "$1" == "-f" || "$1" == "--force" ]]; then
        force=true
        nocache="--no-cache"
        echo -e "🔨 ${YELLOW}Force rebuild${NC} requested"
    fi

    # Validate host paths (fail if missing, do not create)
    if ! validate_host_paths; then
        echo "error: fix missing paths before building" >&2
            exit 1
        fi

    # Build/validate tools volume (has its own trap)
    if ! build_tools_volume "$force" "$nocache"; then
        echo "error: tools build failed" >&2
        exit 1
    fi

    # Trap for image build phase
    trap 'echo -e "\n${RED}build interrupted${NC}" >&2; exit 130' INT TERM

    # Prepare terminfo
    echo -e "📄 Preparing terminfo..."
    mkdir -p "$C0ROOT/docker/.terminfo"
    for term in xterm-256color $TERM; do
        infocmp -xa "$term" > "$C0ROOT/docker/.terminfo/$term" 2>/dev/null || true
    done

    # Build service image
    echo -e "🏗️  Building service image..."
    if ! dc build $nocache "$MAIN_SERVICE"; then
        echo "error: image build failed" >&2
        exit 1
    fi

    trap - INT TERM

    # Update pin on successful build (Phase 3)
    if [[ "$IN_CONTAINER" == "false" ]]; then
        local folder_id
        folder_id="$(compute_folder_id)"
        if [[ -n "$folder_id" ]]; then
            write_pin_for_folder_id "$folder_id" "$DOCKERFILE_HASH" "$C0ROOT" "$C0_MODE"
        fi
    fi

    # Run garbage collection after successful build (Phase 5)
    gc_tools_hashes

    echo -e "✅ ${GREEN}Build complete${NC}"
}

cmd_clean() {
    require_host "clean"

    # Try to promote any staged .next build for current hash (Phase 4)
    maybe_promote_staged_next "$DOCKERFILE_HASH"

    local clean_all=false
    if [[ "$1" == "--all" || "$1" == "-a" ]]; then
        clean_all=true
    fi

    if [[ "$clean_all" == "true" ]]; then
        # Remove entire volume
        local containers
        containers=$(docker ps -aq --filter "volume=$SHARED_TOOLS_VOLUME" 2>/dev/null | tr '\n' ' ')
        if [[ -n "$containers" ]]; then
            echo -e "🛑 Removing containers using volume..."
            docker rm -f $containers >/dev/null
        fi

        echo -e "🧹 Removing volume ${CYAN}$SHARED_TOOLS_VOLUME${NC}..."
        if docker volume rm "$SHARED_TOOLS_VOLUME" >/dev/null 2>&1; then
            echo -e "✅ Removed: ${GREEN}$SHARED_TOOLS_VOLUME${NC}"
        else
            if docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
                echo "error: failed to remove $SHARED_TOOLS_VOLUME (in use?)" >&2
                exit 1
            else
                echo -e "${YELLOW}$SHARED_TOOLS_VOLUME does not exist${NC}"
            fi
        fi
    else
        # Remove current + pinned hash folders and unpin (Phase 3)
        if ! docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
            echo -e "${YELLOW}volume $SHARED_TOOLS_VOLUME does not exist${NC}"
            return 0
        fi

        local current_hash="$DOCKERFILE_HASH"
        local pinned_hash=""
        local folder_id
        folder_id="$(compute_folder_id)"
        if [[ -n "$folder_id" ]]; then
            pinned_hash="$(read_pin_for_folder_id "$folder_id")"
        fi

        # Collect unique hashes to remove
        local -a hashes_to_remove=("$current_hash")
        if [[ -n "$pinned_hash" && "$pinned_hash" != "$current_hash" ]]; then
            hashes_to_remove+=("$pinned_hash")
        fi

        echo -e "🧹 Cleaning tools for this folder..."
        for hash in "${hashes_to_remove[@]}"; do
            if tools_volume_sh "test -d '/tools/opt/$hash'" 2>/dev/null; then
                if tools_volume_sh "rm -rf '/tools/opt/$hash'" 2>/dev/null; then
                    echo -e "  ✅ Removed: ${GREEN}/tools/opt/${hash:0:12}...${NC}"
                else
                    echo "error: failed to remove /tools/opt/$hash" >&2
                    exit 1
                fi
            fi
        done

        # Delete pin file
        if [[ -n "$folder_id" ]]; then
            delete_pin_for_folder_id "$folder_id"
            echo -e "  ✅ Removed pin"
        fi

        # Run garbage collection after clean (Phase 5)
        gc_tools_hashes
    fi
}

cmd_help() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        cat <<EOF
Usage: c0 {help}

Commands (inside container):
  help          Show this help message

Note: Running inside container. Use 'exit' to return to host.
EOF
    else
        cat <<EOF
Usage: c0 {start|stop|restart|logs|status|sh|root|cp-term|build|clean|help}

Commands:
  start         Start all services
  stop          Stop all services
  restart       Restart all services
  logs [svc]    Show logs (default: $MAIN_SERVICE)
  status        Show service status and volume mappings
  sh            Shell as dev user (uid 1000)
  root          Shell as root (uid 0)
  cp-term       Copy terminfo into container
  build [-f]    Build tools and image (-f forces rebuild)
                Pins current Dockerfile hash on success for this folder.
                Triggers automatic cleanup of unpinned/inactive hashes.
  clean [-a]    Remove tools for current + pinned hashes; unpins this folder.
                Runs garbage collection. (-a removes entire shared volume)
  help          Show this help message

Environment:
  C0_MODE       Set to 'dev' for dev mode (default: production)

Notes:
  - Each folder pins its latest successful build hash
  - Active hashes (from running containers) are never garbage collected
  - Force rebuild of active hash stages to .next, promotes after stop
EOF
    fi
}

# =============================================================================
# Main
# =============================================================================

case "${1:-}" in
    start)      cmd_start ;;
    stop)       cmd_stop ;;
    restart)    cmd_restart ;;
    logs)       shift; cmd_logs "$@" ;;
    status)     cmd_status ;;
    sh)         cmd_sh ;;
    root)       cmd_root ;;
    cp-term)    cmd_cp_term ;;
    build)      shift; cmd_build "$@" ;;
    clean)      shift; cmd_clean "$@" ;;
    help|--help|-h)
                cmd_help ;;
    *)
        if [[ "$IN_CONTAINER" == "false" ]]; then
            cmd_status
            echo ""
        fi
        cmd_help
        ;;
esac
