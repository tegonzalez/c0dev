#!/bin/sh

# Intended to be sourced (POSIX): `. ./activate`
# Works in sh and bash; avoids bash arrays and `source`.

prepend_path() {
	p=$1
	[ -n "$p" ] || return 0
	[ -d "$p" ] || return 0
	case ":${PATH}:" in
	*:"$p":*)
		;;
	*)
		if [ -n "${PATH}" ]; then
			PATH="$p:$PATH"
		else
			PATH="$p"
		fi
		;;
	esac
}

# Standard tool locations (symlinked to shared volume in container)
prepend_path "/usr/local/bun-node-fallback-bin"
prepend_path "$HOME/.cargo/bin"
prepend_path "$HOME/.local/bin"
prepend_path "$HOME/bin"

export PATH
