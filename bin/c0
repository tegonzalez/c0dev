#!/bin/bash

# Service management script for c0dev environment
# Usage: ./c0 [start [--cap-drop-all]|stop|restart [--cap-drop-all]|...|help]

set -e

# =============================================================================
# Colors for output
# =============================================================================

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m' # No Color

# =============================================================================
# Preconditions (fail-fast)
# =============================================================================

C0ROOT="$(realpath "$(dirname "$0")/..")"

# Required files - exit non-zero if any are missing
REQUIRED_FILES=(
    "$C0ROOT/docker/docker-compose.public.yaml"
    "$C0ROOT/docker/docker-compose.ssh-auth.yaml"
    "$C0ROOT/docker/volumes-folders.yaml"
    "$C0ROOT/docker/volumes-files.yaml"
    "$C0ROOT/docker/Dockerfile"
    "$C0ROOT/docker/seccomp/moby-default-seccomp.json"
    "$C0ROOT/docker/seccomp/moby-default-seccomp.sha256"
    "$C0ROOT/docker/seccomp/moby-seccomp.tag"
    "$C0ROOT/docker/docker-compose.security-permissive.yaml"
    "$C0ROOT/docker/docker-compose.security-cap-drop-all.yaml"
)

for f in "${REQUIRED_FILES[@]}"; do
    if [[ ! -f "$f" ]]; then
        echo "error: required file missing: $f" >&2
        exit 1
    fi
done

# Detect if running inside container
if [[ -f /.dockerenv ]] || grep -q docker /proc/1/cgroup 2>/dev/null; then
    IN_CONTAINER=true
else
    IN_CONTAINER=false
fi

# =============================================================================
# Mode and project naming
# =============================================================================

# =============================================================================
# Web port allocation
# =============================================================================

# Host port range used to map guest:3000 -> host:<port>
C0DEV_WEB_PORT_MIN=3000
C0DEV_WEB_PORT_MAX=4000

# C0_MODE validation: only "" (prod) or "dev" allowed
if [[ -n "$C0_MODE" && "$C0_MODE" != "dev" ]]; then
    echo "error: C0_MODE must be empty (production) or 'dev', got: '$C0_MODE'" >&2
    exit 1
fi

# Short hash function (first 8 chars of sha256)
short_hash() {
    echo -n "$1" | shasum -a 256 | cut -c1-8
}

# Project naming based on mode
if [[ "$C0_MODE" == "dev" ]]; then
    PROJECT_NAME="c0dev-dev-$(short_hash "${C0ROOT}:dev")"
    SHARED_TOOLS_VOLUME="c0dev-tools-shared-dev"
else
    PROJECT_NAME="c0dev-$(short_hash "$C0ROOT")"
    SHARED_TOOLS_VOLUME="c0dev-tools-shared"
fi

# Dockerfile hash for tools prefix
DOCKERFILE_HASH="$(shasum -a 256 "$C0ROOT/docker/Dockerfile" | cut -c1-64)"
TOOLS_PREFIX="/tools/opt/$DOCKERFILE_HASH"

# =============================================================================
# Compose file paths
# =============================================================================

COMPOSE_PUBLIC_FILE="$C0ROOT/docker/docker-compose.public.yaml"
COMPOSE_SECURITY_PERMISSIVE="$C0ROOT/docker/docker-compose.security-permissive.yaml"
COMPOSE_SECURITY_CAP_DROP_ALL="$C0ROOT/docker/docker-compose.security-cap-drop-all.yaml"
COMPOSE_SSH_AUTH_FILE="$C0ROOT/docker/docker-compose.ssh-auth.yaml"
COMPOSE_LOCAL_FILE="$C0ROOT/docker/docker-compose.local.yaml"
C0_SSH_AUTH_SOCK_GUEST="/home/dev/.ssh-auth.sock"
C0_SSH_AUTH_SOCK_GID_DEFAULT="67278"
VOLUMES_FOLDERS_FILE="$C0ROOT/docker/volumes-folders.yaml"
VOLUMES_FILES_FILE="$C0ROOT/docker/volumes-files.yaml"
MAIN_SERVICE="c0dev"
CONTAINER_DEV_HOME="/home/dev"

# Vendored Moby reference seccomp (tag in docker/seccomp/moby-seccomp.tag)
SECCOMP_DIR="$C0ROOT/docker/seccomp"
SECCOMP_PROFILE_JSON="$SECCOMP_DIR/moby-default-seccomp.json"
SECCOMP_PROFILE_SHA="$SECCOMP_DIR/moby-default-seccomp.sha256"
SECCOMP_LOCAL_TAG_FILE="$SECCOMP_DIR/moby-seccomp.tag"
MOBY_PROFILES_GIT_URL="${MOBY_PROFILES_GIT_URL:-https://github.com/moby/profiles.git}"
# Cache remote "latest" probe (git ls-remote + raw profile sha256); TTL limits network (seconds)
C0_SECCOMP_REMOTE_CACHE_TTL="${C0_SECCOMP_REMOTE_CACHE_TTL:-21600}"
C0_SECCOMP_CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/c0dev"
C0_SECCOMP_REMOTE_CACHE="$C0_SECCOMP_CACHE_DIR/moby-seccomp-remote.cache"
C0_DOCKER_AUTOSTART="${C0_DOCKER_AUTOSTART:-1}"
C0_DOCKER_START_TIMEOUT="${C0_DOCKER_START_TIMEOUT:-60}"

# Ephemeral docker run helpers (tools volume I/O, unpack): align with least-privilege posture.
# Runtime service hardening: docker-compose.security-*.yaml (selected via C0_SECURITY).
c0_docker_run() {
    docker run --rm \
        --security-opt no-new-privileges:true \
        --cap-drop ALL \
        "$@"
}

# Refuse start/build if vendored seccomp was tampered with or removed.
verify_moby_seccomp_profile() {
    if [[ ! -f "$SECCOMP_PROFILE_JSON" ]]; then
        echo "error: seccomp profile missing: $SECCOMP_PROFILE_JSON" >&2
        return 1
    fi
    if [[ ! -f "$SECCOMP_PROFILE_SHA" ]]; then
        echo "error: seccomp checksum file missing: $SECCOMP_PROFILE_SHA" >&2
        return 1
    fi
    if ! (cd "$SECCOMP_DIR" && shasum -a 256 -c "moby-default-seccomp.sha256"); then
        echo "error: seccomp profile failed checksum verification" >&2
        return 1
    fi
    return 0
}

# --- Moby seccomp: query upstream, optional cache, user-driven upgrade (see cmd_seccomp_upgrade) ---

read_local_seccomp_tag() {
    if [[ ! -f "$SECCOMP_LOCAL_TAG_FILE" ]]; then
        echo ""
        return 0
    fi
    tr -d ' \t\r\n' <"$SECCOMP_LOCAL_TAG_FILE" | head -c 200
}

read_local_seccomp_profile_sha256() {
    if [[ ! -f "$SECCOMP_PROFILE_SHA" ]]; then
        echo ""
        return 0
    fi
    awk '{print $1; exit}' "$SECCOMP_PROFILE_SHA"
}

# Resolve latest seccomp/vM.m.p on upstream using git ls-remote (TLS to GitHub).
# Annotated tags: use peeled refs/tags/...^{}; lightweight: single ref line.
# Prints: remote_tag<TAB>commit_oid on stdout; return 1 if none or git missing.
moby_seccomp_resolve_upstream_latest() {
    if ! command -v git &>/dev/null; then
        return 1
    fi
    local lsout
    lsout="$(GIT_TERMINAL_PROMPT=0 git ls-remote --tags "$MOBY_PROFILES_GIT_URL" 2>/dev/null)" || return 1
    [[ -z "$lsout" ]] && return 1

    local pairs
    pairs="$(echo "$lsout" | awk '
    $2 ~ /^refs\/tags\/seccomp\/v[0-9]+\.[0-9]+\.[0-9]+\^\{\}$/ {
      n = $2
      sub(/^refs\/tags\//,"",n)
      sub(/\^\{\}$/,"",n)
      pe[n] = $1
      next
    }
    $2 ~ /^refs\/tags\/seccomp\/v[0-9]+\.[0-9]+\.[0-9]+$/ {
      n = $2
      sub(/^refs\/tags\//,"",n)
      lw[n] = $1
      next
    }
    END {
      for (n in lw) {
        if (n in pe) print n "\t" pe[n]
        else print n "\t" lw[n]
      }
    }')" || true
    [[ -z "$pairs" ]] && return 1

    local best_line
    best_line="$(
        while IFS=$'\t' read -r tag commit; do
            [[ -z "$tag" || -z "$commit" ]] && continue
            local ver="${tag#seccomp/v}"
            [[ "$ver" == "$tag" ]] && continue
            printf '%s\t%s\t%s\n' "$ver" "$tag" "$commit"
        done <<<"$pairs" | sort -t$'\t' -k1,1V | tail -1
    )" || true
    [[ -z "$best_line" ]] && return 1

    local remote_tag remote_commit
    remote_tag="$(echo "$best_line" | cut -f2)"
    remote_commit="$(echo "$best_line" | cut -f3)"
    [[ -z "$remote_tag" || -z "$remote_commit" ]] && return 1
    printf '%s\t%s\n' "$remote_tag" "$remote_commit"
}

# Exit 0 if $1 is semver-newer than $2 (both seccomp/vM.m.p); else 1.
moby_seccomp_tag_a_gt_b() {
    local a="${1#seccomp/v}"
    local b="${2#seccomp/v}"
    if [[ "$a" == "$1" || "$b" == "$2" ]]; then
        return 1
    fi
    if [[ "$(printf '%s\n' "$b" "$a" | sort -V | tail -1)" == "$a" ]] && [[ "$a" != "$b" ]]; then
        return 0
    fi
    return 1
}

# sha256 of default.json body for a tag (hex only).
moby_seccomp_profile_sha256_for_tag() {
    local tag="$1"
    local url="https://raw.githubusercontent.com/moby/profiles/refs/tags/${tag}/seccomp/default.json"
    curl -fsSL --connect-timeout 5 --max-time 45 \
        -H "User-Agent: c0dev-seccomp-check" \
        "$url" 2>/dev/null | shasum -a 256 | awk '{print $1}'
}

moby_seccomp_remote_cache_read_field() {
    local key="$1"
    [[ ! -f "$C0_SECCOMP_REMOTE_CACHE" ]] && return 0
    grep "^${key}=" "$C0_SECCOMP_REMOTE_CACHE" 2>/dev/null | head -1 | cut -d= -f2-
}

moby_seccomp_remote_cache_write() {
    local latest_tag="$1"
    local commit_sha="$2"
    local profile_sha="$3"
    mkdir -p "$C0_SECCOMP_CACHE_DIR"
    local now
    now="$(date +%s)"
    cat >"$C0_SECCOMP_REMOTE_CACHE" <<EOF
checked_epoch=$now
latest_tag=$latest_tag
commit_sha=$commit_sha
profile_sha256=$profile_sha
EOF
}

moby_seccomp_remote_cache_valid() {
    [[ ! -f "$C0_SECCOMP_REMOTE_CACHE" ]] && return 1
    local checked
    checked="$(moby_seccomp_remote_cache_read_field checked_epoch)"
    [[ -z "$checked" ]] && return 1
    local now age
    now="$(date +%s)"
    age=$((now - checked))
    [[ "$age" -lt "$C0_SECCOMP_REMOTE_CACHE_TTL" ]]
}

# After verify_moby: optionally notify if upstream has a newer seccomp tag than vendored.
# Set C0_SECCOMP_NOTIFY=0 to skip. Uses git ls-remote + curl (no JSON parser); failures are silent.
maybe_notify_seccomp_update_available() {
    if [[ "${C0_SECCOMP_NOTIFY:-1}" == "0" ]]; then
        return 0
    fi
    if ! command -v git &>/dev/null; then
        return 0
    fi

    local local_tag profile_local
    local_tag="$(read_local_seccomp_tag)"
    profile_local="$(read_local_seccomp_profile_sha256)"
    if [[ -z "$local_tag" ]]; then
        return 0
    fi

    local remote_tag remote_commit remote_profile use_cache=false
    if moby_seccomp_remote_cache_valid; then
        remote_tag="$(moby_seccomp_remote_cache_read_field latest_tag)"
        remote_commit="$(moby_seccomp_remote_cache_read_field commit_sha)"
        remote_profile="$(moby_seccomp_remote_cache_read_field profile_sha256)"
        if [[ -n "$remote_tag" && -n "$remote_profile" ]]; then
            use_cache=true
        fi
    fi

    if [[ "$use_cache" != true ]]; then
        local pair
        if ! pair="$(moby_seccomp_resolve_upstream_latest)"; then
            return 0
        fi
        remote_tag="$(echo "$pair" | cut -f1)"
        remote_commit="$(echo "$pair" | cut -f2)"
        [[ -z "$remote_tag" ]] && return 0
        remote_profile="$(moby_seccomp_profile_sha256_for_tag "$remote_tag")"
        [[ -z "$remote_profile" ]] && return 0
        moby_seccomp_remote_cache_write "$remote_tag" "$remote_commit" "$remote_profile"
    fi

    if ! moby_seccomp_tag_a_gt_b "$remote_tag" "$local_tag"; then
        return 0
    fi

    local ts
    ts="$(date -u +"%Y-%m-%dT%H:%M:%SZ")"
    echo "" >&2
    echo -e "${YELLOW}${BOLD}c0 seccomp:${NC} newer Moby profile available than vendored copy." >&2
    echo -e "  ${BOLD}upstream tag:${NC}           ${CYAN}$remote_tag${NC}" >&2
    echo -e "  ${BOLD}upstream commit (git):${NC}    ${CYAN}$remote_commit${NC}" >&2
    echo -e "  ${BOLD}upstream profile sha256:${NC} ${CYAN}$remote_profile${NC}" >&2
    echo -e "  ${BOLD}vendored tag:${NC}            ${MAGENTA}$local_tag${NC}" >&2
    echo -e "  ${BOLD}vendored profile sha256:${NC} ${MAGENTA}$profile_local${NC}" >&2
    echo -e "  ${BOLD}notice generated (UTC):${NC}   $ts" >&2
    echo -e "  Run ${GREEN}c0 seccomp-upgrade${NC} to download and replace ${CYAN}docker/seccomp/*${NC} (optional: ${GREEN}--dry-run${NC})." >&2
    echo "" >&2
    return 0
}

cmd_seccomp_upgrade() {
    require_host "seccomp-upgrade"

    if ! command -v git &>/dev/null; then
        echo "error: git is required for seccomp-upgrade (git ls-remote to moby/profiles)" >&2
        exit 1
    fi

    if [[ ! -f "$SECCOMP_LOCAL_TAG_FILE" ]] || [[ -z "$(read_local_seccomp_tag)" ]]; then
        echo "error: missing or empty $SECCOMP_LOCAL_TAG_FILE" >&2
        exit 1
    fi

    local dry_run=false
    if [[ "${1:-}" == "--dry-run" || "${1:-}" == "-n" ]]; then
        dry_run=true
    fi

    local pair remote_tag remote_commit
    if ! pair="$(moby_seccomp_resolve_upstream_latest)"; then
        echo "error: git ls-remote failed or no seccomp/vM.m.p tags (network, auth, or repo URL)" >&2
        exit 1
    fi
    remote_tag="$(echo "$pair" | cut -f1)"
    remote_commit="$(echo "$pair" | cut -f2)"

    local local_tag
    local_tag="$(read_local_seccomp_tag)"

    if [[ "$remote_tag" == "$local_tag" ]]; then
        echo -e "${GREEN}seccomp:${NC} already on latest Moby tag ${CYAN}$remote_tag${NC}"
        moby_seccomp_remote_cache_write "$remote_tag" "$remote_commit" "$(moby_seccomp_profile_sha256_for_tag "$remote_tag")"
        exit 0
    fi

    if ! moby_seccomp_tag_a_gt_b "$remote_tag" "$local_tag"; then
        echo -e "${YELLOW}seccomp:${NC} vendored tag ${MAGENTA}$local_tag${NC} is newer than upstream latest ${CYAN}$remote_tag${NC} (no downgrade)." >&2
        exit 0
    fi

    local remote_profile url
    remote_profile="$(moby_seccomp_profile_sha256_for_tag "$remote_tag")"
    if [[ -z "$remote_profile" ]]; then
        echo "error: failed to download or hash profile for $remote_tag" >&2
        exit 1
    fi
    url="https://raw.githubusercontent.com/moby/profiles/refs/tags/${remote_tag}/seccomp/default.json"

    echo -e "${BOLD}Moby seccomp upgrade${NC}"
    echo -e "  from: ${MAGENTA}$local_tag${NC} (profile sha256 $(read_local_seccomp_profile_sha256))"
    echo -e "  to:   ${CYAN}$remote_tag${NC}"
    echo -e "  commit (git peeled ref): ${CYAN}$remote_commit${NC}"
    echo -e "  new profile sha256: ${CYAN}$remote_profile${NC}"
    echo -e "  url: ${BLUE}$url${NC}"

    if [[ "$dry_run" == true ]]; then
        echo -e "${YELLOW}dry-run:${NC} no files written. Remove --dry-run to apply."
        exit 0
    fi

    local tmpjson
    tmpjson="$(mktemp "${TMPDIR:-/tmp}/c0-seccomp-json.XXXXXX")"
    if ! curl -fsSL --connect-timeout 5 --max-time 60 \
        -H "User-Agent: c0dev-seccomp-check" \
        "$url" -o "$tmpjson"; then
        rm -f "$tmpjson"
        echo "error: failed to download profile" >&2
        exit 1
    fi
    local gotsha
    gotsha="$(shasum -a 256 "$tmpjson" | awk '{print $1}')"
    if [[ "$gotsha" != "$remote_profile" ]]; then
        rm -f "$tmpjson"
        echo "error: downloaded profile sha256 mismatch (expected $remote_profile got $gotsha)" >&2
        exit 1
    fi

    mv "$tmpjson" "$SECCOMP_PROFILE_JSON"
    (
        cd "$SECCOMP_DIR" || exit 1
        shasum -a 256 moby-default-seccomp.json >moby-default-seccomp.sha256.tmp
        mv moby-default-seccomp.sha256.tmp moby-default-seccomp.sha256
    )
    printf '%s\n' "$remote_tag" >"$SECCOMP_LOCAL_TAG_FILE"
    rm -f "$C0_SECCOMP_REMOTE_CACHE" 2>/dev/null || true

    if ! verify_moby_seccomp_profile; then
        echo "error: upgraded files failed verification (restore from git)" >&2
        exit 1
    fi

    echo -e "${GREEN}seccomp:${NC} wrote ${CYAN}$SECCOMP_PROFILE_JSON${NC}, checksum, and ${CYAN}$SECCOMP_LOCAL_TAG_FILE${NC}"
    exit 0
}

# =============================================================================
# C0_SECURITY: permissive (default) | cap-drop-all — env or start/restart --cap-drop-all
# =============================================================================

validate_c0_security_value() {
    case "$1" in
        permissive|cap-drop-all) return 0 ;;
        *)
            echo "error: C0_SECURITY must be 'permissive' or 'cap-drop-all', got: '$1'" >&2
            return 1
            ;;
    esac
}

c0_security_compose_file() {
    case "$C0_SECURITY" in
        permissive) echo "$COMPOSE_SECURITY_PERMISSIVE" ;;
        cap-drop-all) echo "$COMPOSE_SECURITY_CAP_DROP_ALL" ;;
        *)
            echo "error: internal: unknown C0_SECURITY=$C0_SECURITY" >&2
            return 1
            ;;
    esac
}

# Running container label (docker inspect; does not use compose).
get_running_container_security_mode() {
    local cid
    cid="$(docker ps -aq -f "label=c0dev.project=${PROJECT_NAME}" 2>/dev/null | head -n 1 || true)"
    [[ -z "$cid" ]] && return 0
    docker inspect "$cid" --format '{{ index .Config.Labels "c0dev.security_mode" }}' 2>/dev/null || true
}

# For dc and display when not starting: match running container, else env, else permissive.
ensure_c0_security_resolved() {
    if [[ -n "${C0_SECURITY_RESOLVED:-}" ]]; then
        return 0
    fi

    local from_container
    from_container="$(get_running_container_security_mode)"
    if [[ -n "$from_container" ]]; then
        if ! validate_c0_security_value "$from_container"; then
            return 1
        fi
        C0_SECURITY="$from_container"
    elif [[ -n "${C0_SECURITY:-}" ]]; then
        if ! validate_c0_security_value "$C0_SECURITY"; then
            return 1
        fi
    else
        C0_SECURITY="permissive"
    fi
    export C0_SECURITY
}

# start/restart only: --cap-drop-all overrides env; default permissive.
resolve_c0_security_for_start() {
    local cli_cap_drop_all=false
    local arg
    for arg in "$@"; do
        case "$arg" in
            --cap-drop-all) cli_cap_drop_all=true ;;
            *)
                echo "error: unknown option: $arg (try --cap-drop-all)" >&2
                return 1
                ;;
        esac
    done

    if [[ "$cli_cap_drop_all" == true ]]; then
        C0_SECURITY="cap-drop-all"
    elif [[ -n "${C0_SECURITY:-}" ]]; then
        if ! validate_c0_security_value "$C0_SECURITY"; then
            return 1
        fi
    else
        C0_SECURITY="permissive"
    fi
    export C0_SECURITY
    export C0_SECURITY_RESOLVED=1
}

print_security_mode() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi
    ensure_c0_security_resolved || return 0
    echo -e "🔒 Security: ${YELLOW}${C0_SECURITY}${NC}"
}

# =============================================================================
# SSH agent: use shell SSH_AUTH_SOCK; macOS Docker VMs use the host relay.
# =============================================================================

resolve_ssh_auth_sock_bind_source() {
    C0_SSH_AUTH_SOCK_BIND_SOURCE=""
    [[ -z "${SSH_AUTH_SOCK:-}" ]] && return 0

    if [[ "$(uname -s)" == "Darwin" ]]; then
        C0_SSH_AUTH_SOCK_BIND_SOURCE="/run/host-services/ssh-auth.sock"
    elif [[ -S "$SSH_AUTH_SOCK" ]]; then
        C0_SSH_AUTH_SOCK_BIND_SOURCE="$SSH_AUTH_SOCK"
    else
        echo -e "${YELLOW}warning:${NC} SSH_AUTH_SOCK is set but not a socket: ${SSH_AUTH_SOCK}" >&2
        echo -e "  SSH agent will not be available in the container (ssh/git may prompt)." >&2
        return 0
    fi
    export C0_SSH_AUTH_SOCK_BIND_SOURCE
    resolve_ssh_auth_sock_gid
}

host_path_gid() {
    local path="$1"
    stat -c '%g' "$path" 2>/dev/null || stat -f '%g' "$path" 2>/dev/null || true
}

resolve_ssh_auth_sock_gid() {
    [[ -n "${C0_SSH_AUTH_SOCK_BIND_SOURCE:-}" ]] || return 0
    [[ -n "${C0_SSH_AUTH_SOCK_GID:-}" ]] && return 0

    local gid=""
    if [[ -S "$C0_SSH_AUTH_SOCK_BIND_SOURCE" ]]; then
        gid="$(host_path_gid "$C0_SSH_AUTH_SOCK_BIND_SOURCE")"
    fi

    case "$gid" in
        ''|*[!0-9]*)
            C0_SSH_AUTH_SOCK_GID="$C0_SSH_AUTH_SOCK_GID_DEFAULT"
            ;;
        *)
            C0_SSH_AUTH_SOCK_GID="$gid"
            ;;
    esac
    export C0_SSH_AUTH_SOCK_GID
}

print_ssh_auth_mapping() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi
    [[ -z "${SSH_AUTH_SOCK:-}" ]] && return 0
    resolve_ssh_auth_sock_bind_source
    if [[ -n "${C0_SSH_AUTH_SOCK_BIND_SOURCE:-}" ]]; then
        echo -e "🔑 SSH agent: ${YELLOW}${C0_SSH_AUTH_SOCK_GUEST}${NC} ← ${C0_SSH_AUTH_SOCK_BIND_SOURCE} (gid ${C0_SSH_AUTH_SOCK_GID:-$C0_SSH_AUTH_SOCK_GID_DEFAULT})"
    fi
}

probe_host_ssh_agent() {
    if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
        echo "disabled"
        return 0
    fi
    if ! command -v ssh-add &>/dev/null; then
        echo "unknown:ssh-add not found"
        return 0
    fi

    local output
    if output="$(ssh-add -l 2>&1)"; then
        echo "ok:$output"
        return 0
    fi

    case "$output" in
        *"The agent has no identities."*)
            echo "empty:$output"
            ;;
        *)
            echo "error:$output"
            ;;
    esac
}

probe_container_ssh_agent() {
    local output
    if output="$(dc exec -T -u 1000 "$MAIN_SERVICE" sh -lc '
        if [ -z "${SSH_AUTH_SOCK:-}" ]; then
            echo "disabled:no SSH_AUTH_SOCK"
            exit 0
        fi
        if [ ! -S "$SSH_AUTH_SOCK" ]; then
            echo "missing:$SSH_AUTH_SOCK"
            exit 0
        fi
        out="$(ssh-add -l 2>&1)"
        code="$?"
        if [ "$code" -eq 0 ]; then
            echo "ok:$out"
            exit 0
        fi
        case "$out" in
            *"The agent has no identities."*) echo "empty:$out" ;;
            *) echo "error:$out" ;;
        esac
    ' 2>&1)"; then
        echo "$output"
    else
        echo "unknown:$output"
    fi
}

print_ssh_probe_line() {
    local label="$1"
    local result="$2"
    local kind="$result"
    local detail=""

    if [[ "$result" == *:* ]]; then
        kind="${result%%:*}"
        detail="${result#*:}"
    fi

    case "$kind" in
        disabled)
            echo -e "  ${YELLOW}${label}:${NC} disabled"
            ;;
        ok)
            echo -e "  ${GREEN}${label}:${NC} reachable"
            ;;
        empty)
            echo -e "  ${YELLOW}${label}:${NC} reachable, no identities loaded"
            ;;
        missing)
            echo -e "  ${RED}${label}:${NC} missing socket ${detail}"
            ;;
        error)
            echo -e "  ${RED}${label}:${NC} ${detail}"
            ;;
        *)
            echo -e "  ${YELLOW}${label}:${NC} ${detail:-unknown}"
            ;;
    esac
}

ssh_probe_failed() {
    local result="$1"
    local kind="$result"

    if [[ "$result" == *:* ]]; then
        kind="${result%%:*}"
    fi

    case "$kind" in
        error|missing|unknown)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

# =============================================================================
# Helper: docker-compose wrapper with project isolation
# =============================================================================

dc() {
    ensure_c0_security_resolved || return 1
    local security_file
    security_file="$(c0_security_compose_file)" || return 1
    resolve_ssh_auth_sock_bind_source

    export SHARED_TOOLS_VOLUME
    export TOOLS_PREFIX
    export DOCKERFILE_HASH
    export C0DEV_HOSTNAME="$PROJECT_NAME"
    export C0_SECURITY
    export C0_SSH_AUTH_SOCK_BIND_SOURCE
    export C0_SSH_AUTH_SOCK_GID

    local -a compose_files=(
        -f "$VOLUMES_FOLDERS_FILE"
        -f "$VOLUMES_FILES_FILE"
        -f "$COMPOSE_PUBLIC_FILE"
        -f "$security_file"
    )
    if [[ -n "${C0_SSH_AUTH_SOCK_BIND_SOURCE:-}" && -f "$COMPOSE_SSH_AUTH_FILE" ]]; then
        compose_files+=(-f "$COMPOSE_SSH_AUTH_FILE")
    fi
    if [[ -f "$COMPOSE_LOCAL_FILE" ]]; then
        compose_files+=(-f "$COMPOSE_LOCAL_FILE")
    fi

    docker compose -p "$PROJECT_NAME" "${compose_files[@]}" "$@"
}

# =============================================================================
# Helper functions
# =============================================================================

get_mapped_web_port_from_container() {
    local container_id="$1"
    docker inspect -f '{{with (index .NetworkSettings.Ports "3000/tcp")}}{{(index . 0).HostPort}}{{end}}' "$container_id" 2>/dev/null || true
}

get_current_web_port() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local container_id
    container_id="$(dc ps -aq "$MAIN_SERVICE" 2>/dev/null | head -n 1 || true)"
    if [[ -n "$container_id" ]]; then
        local mapped
        mapped="$(get_mapped_web_port_from_container "$container_id")"
        if [[ -n "$mapped" ]]; then
            echo "$mapped"
            return 0
        fi
    fi

    if [[ -n "${C0DEV_WEB_PORT:-}" ]]; then
        echo "$C0DEV_WEB_PORT"
        return 0
    fi
}

ensure_web_port() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if [[ -n "${C0DEV_WEB_PORT:-}" ]]; then
        return 0
    fi

    local start="$C0DEV_WEB_PORT_MIN"
    local end="$C0DEV_WEB_PORT_MAX"
    local ports_cmd="$C0ROOT/bin/list-listening-ports"
    if [[ ! -x "$ports_cmd" ]]; then
        echo "error: missing required helper: $ports_cmd" >&2
        return 1
    fi

    # Finds the first integer >= start that is not present in the provided set.
    # Signature: first_gap_port <start> [ports...]
    # Assumes the list is sorted ascending (as produced by bin/list-listening-ports).
    first_gap_port() {
        local start="$1"
        shift

        local candidate="$start"
        local port
        for port in "$@"; do
            case "$port" in
                ''|*[!0-9]*) continue ;;
            esac

            if [[ "$port" -lt "$candidate" ]]; then
                continue
            fi
            if [[ "$port" -eq "$candidate" ]]; then
                candidate=$((candidate + 1))
                continue
            fi

            # port > candidate means candidate is a gap
            echo "$candidate"
            return 0
        done

        echo "$candidate"
        return 0
    }

    local ports
    if ! ports="$("$ports_cmd" "$start" "$end")"; then
        return 1
    fi

    local next
    local -a port_list=()
    if [[ -n "$ports" ]]; then
        local line
        while IFS= read -r line; do
            [[ -z "$line" ]] && continue
            port_list+=("$line")
        done <<<"$ports"
    fi

    next="$(first_gap_port "$start" "${port_list[@]}")"

    if [[ "$next" -gt "$end" ]]; then
        echo "error: no ports left in range ${start}-${end}" >&2
        return 1
    fi

    C0DEV_WEB_PORT="$next"
    export C0DEV_WEB_PORT
}

print_web_port_mapping() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local port
    port="$(get_current_web_port || true)"
    if [[ -n "$port" ]]; then
        echo -e "🌐 Port: ${YELLOW}host:${port}${NC} -> ${YELLOW}guest:3000${NC}"
    fi
}

# Resolve a host path from a docker volume mapping into an absolute path.
resolve_volume_host_path() {
    local host_path="$1"
    local abs_host_path="$host_path"

    if [[ "$abs_host_path" == "~" ]]; then
        abs_host_path="$HOME"
    elif [[ "$abs_host_path" == \~/* ]]; then
        abs_host_path="$HOME/${abs_host_path:2}"
    fi

    if [[ "$abs_host_path" =~ ^\.\. ]]; then
        abs_host_path="$C0ROOT/${abs_host_path#../}"
    elif [[ "$abs_host_path" =~ ^\. ]]; then
        abs_host_path="$C0ROOT/docker/${abs_host_path#./}"
    fi

    echo "$abs_host_path"
}

# Check if path looks like a docker volume name (not a host path)
is_docker_volume() {
    local path="$1"
    # Docker volumes don't start with /, ~, or .
    [[ ! "$path" =~ ^[/~.] ]]
}

# Convert absolute path to display path relative to C0ROOT
to_display_path() {
    local abs_path="$1"
    if [[ "$abs_path" == "$C0ROOT"/* ]]; then
        echo ".${abs_path#"$C0ROOT"}"
    elif [[ "$abs_path" == "$HOME"/* ]]; then
        echo "~${abs_path#"$HOME"}"
    else
        echo "$abs_path"
    fi
}

# Parse volumes-folders.yaml for folder mappings
# Calls callback: callback_func "$abs_host_path" "$container_path" "folder" "$display_host_path" "$ro"
parse_folder_mappings() {
    local callback_func="$1"
    local in_folders=false

    while IFS= read -r line; do
        if [[ "$line" =~ ^x-volume-folders:[[:space:]]*\&folders ]]; then
            in_folders=true
            continue
        fi

        if [[ "$in_folders" == true && "$line" =~ ^[^[:space:]#] ]]; then
            in_folders=false
        fi

        if [[ "$in_folders" == true && "$line" =~ ^[[:space:]]+-[[:space:]]*(.+)$ ]]; then
            local volume_line="${BASH_REMATCH[1]}"
            volume_line="${volume_line%%#*}"
            volume_line=$(echo "$volume_line" | xargs)
            [[ -z "$volume_line" ]] && continue

            local host_path container_path ro
            # Parse host:container or host:container:ro
            IFS=':' read -r host_path container_path ro <<< "$volume_line"

            if is_docker_volume "$host_path"; then
                # Docker volume, not a host path
                "$callback_func" "" "$container_path" "docker-volume" "$host_path" "$ro"
            else
                local abs_host_path display_path
                abs_host_path="$(resolve_volume_host_path "$host_path")"
                display_path="$(to_display_path "$abs_host_path")"
                "$callback_func" "$abs_host_path" "$container_path" "host-dir" "$display_path" "$ro"
            fi
        fi
    done < "$VOLUMES_FOLDERS_FILE"
}

# Parse volumes-files.yaml for file mappings
# Calls callback: callback_func "$abs_host_path" "$container_path" "file" "$display_host_path" "$ro"
parse_file_mappings() {
    local callback_func="$1"
    local in_files=false

    while IFS= read -r line; do
        if [[ "$line" =~ ^x-volume-files:[[:space:]]*\&files ]]; then
            in_files=true
            continue
        fi

        if [[ "$in_files" == true && "$line" =~ ^[^[:space:]#] ]]; then
            break
        fi

        if [[ "$in_files" == true && "$line" =~ ^[[:space:]]+-[[:space:]]*(.+)$ ]]; then
            local volume_line="${BASH_REMATCH[1]}"
            volume_line="${volume_line%%#*}"
            volume_line=$(echo "$volume_line" | xargs)
            [[ -z "$volume_line" ]] && continue

            local host_path container_path ro
            IFS=':' read -r host_path container_path ro <<< "$volume_line"

            if is_docker_volume "$host_path"; then
                "$callback_func" "" "$container_path" "docker-volume" "$host_path" "$ro"
            else
                local abs_host_path display_path
                abs_host_path="$(resolve_volume_host_path "$host_path")"
                display_path="$(to_display_path "$abs_host_path")"
                "$callback_func" "$abs_host_path" "$container_path" "host-file" "$display_path" "$ro"
            fi
        fi
    done < "$VOLUMES_FILES_FILE"
}

# Validate all host paths exist and are correct type
# Returns 0 if valid, 1 if errors; prints errors to stderr
validate_host_paths() {
    local errors=()
    local missing_dirs=()
    local missing_files=()

    _validate_folder_callback() {
    local abs_host_path="$1"
    local container_path="$2"
        local type="$3"
        local display_path="$4"

        if [[ "$type" == "host-dir" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                errors+=("missing: $display_path")
                missing_dirs+=("$abs_host_path")
            elif [[ ! -d "$abs_host_path" ]]; then
                errors+=("not a directory (remove file first): $display_path")
            fi
        fi
    }

    _validate_file_callback() {
        local abs_host_path="$1"
        local container_path="$2"
        local type="$3"
        local display_path="$4"

        if [[ "$type" == "host-file" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                errors+=("missing: $display_path")
                missing_files+=("$abs_host_path")
            elif [[ ! -f "$abs_host_path" ]]; then
                errors+=("not a file: $display_path")
            fi
        fi
    }

    parse_folder_mappings _validate_folder_callback
    parse_file_mappings _validate_file_callback

    if [[ ${#errors[@]} -gt 0 ]]; then
        echo "error: host path validation failed:" >&2
        for err in "${errors[@]}"; do
            echo "  - $err" >&2
        done
        # Suggest fix for missing paths
        if [[ ${#missing_dirs[@]} -gt 0 || ${#missing_files[@]} -gt 0 ]]; then
            echo "" >&2
            echo "create missing paths:" >&2
            for d in "${missing_dirs[@]}"; do
                echo "  mkdir -p \"$d\"" >&2
            done
            for f in "${missing_files[@]}"; do
                echo "  touch \"$f\"" >&2
            done
        fi
        return 1
    fi
    return 0
}

host_path_safe_to_create() {
    local abs_host_path="$1"

    [[ "$abs_host_path" == "$C0ROOT"/* ]] || return 1
    [[ "$abs_host_path" != *"/../"* ]] || return 1
    [[ "$abs_host_path" != *"/.." ]] || return 1
}

# Create missing host directories from volume mappings.
# Host files remain explicit: c0 will not invent credential/config files.
ensure_host_dirs() {
    local created=()
    local errors=()

    _ensure_folder_callback() {
        local abs_host_path="$1"
        local container_path="$2"
        local type="$3"
        local display_path="$4"

        if [[ "$type" == "host-dir" && -n "$abs_host_path" && ! -e "$abs_host_path" ]]; then
            if ! host_path_safe_to_create "$abs_host_path"; then
                errors+=("$display_path (outside c0 root)")
                return 0
            fi
            if mkdir -p "$abs_host_path"; then
                created+=("$display_path")
            else
                errors+=("$display_path")
            fi
        fi
    }

    parse_folder_mappings _ensure_folder_callback

    if [[ ${#created[@]} -gt 0 ]]; then
        echo -e "🧭 Host paths: created missing directories"
        local d
        for d in "${created[@]}"; do
            echo -e "  ${GREEN}+${NC} $d"
        done
    fi

    if [[ ${#errors[@]} -gt 0 ]]; then
        echo "error: failed to create host directories:" >&2
        local err
        for err in "${errors[@]}"; do
            echo "  - $err" >&2
        done
        return 1
    fi
    return 0
}

ensure_host_paths() {
    ensure_host_dirs || return 1
    validate_host_paths
}

# Check if shared tools volume exists and is valid for current Dockerfile hash
tools_volume_valid() {
    # Check if volume exists
    if ! docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
        return 1
    fi

    # Check if completeness marker exists
    c0_docker_run -v "$SHARED_TOOLS_VOLUME:/tools:ro" alpine \
        test -f "/tools/opt/$DOCKERFILE_HASH/.c0dev-complete" 2>/dev/null
}

# Get project relative path for shell navigation
get_project_path() {
    local current_dir
    current_dir="$(realpath "$(pwd)")"
    local projects_dir="$C0ROOT/projects"

    if [[ "$current_dir" == "$projects_dir" ]]; then
        echo "."
    elif [[ "$current_dir" == "$projects_dir"* ]]; then
        echo "${current_dir#"$projects_dir"/}"
    else
        echo ""
    fi
}

# Host-only guard
require_host() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        echo "error: '$1' must be run from host, not inside container" >&2
        exit 1
    fi
}

# =============================================================================
# Host Docker daemon preflight
# =============================================================================

docker_endpoint_hint() {
    if [[ -n "${DOCKER_HOST:-}" ]]; then
        echo "$DOCKER_HOST"
        return 0
    fi
    if ! command -v docker &>/dev/null; then
        return 0
    fi
    docker context inspect --format '{{ with (index .Endpoints "docker") }}{{ .Host }}{{ end }}' 2>/dev/null | head -1 || true
}

orbstack_app_available() {
    [[ -d "/Applications/OrbStack.app" || -d "$HOME/Applications/OrbStack.app" ]]
}

docker_endpoint_looks_orbstack() {
    local endpoint
    endpoint="$(docker_endpoint_hint)"
    [[ "$endpoint" == *orbstack* || "$endpoint" == *OrbStack* ]]
}

maybe_start_orbstack() {
    [[ "$C0_DOCKER_AUTOSTART" != "0" ]] || return 1
    [[ -z "${CI:-}" ]] || return 1
    [[ "$(uname -s)" == "Darwin" ]] || return 1
    command -v open &>/dev/null || return 1
    if ! docker_endpoint_looks_orbstack && ! orbstack_app_available; then
        return 1
    fi
    echo -e "🐳 Docker: unavailable; starting ${CYAN}OrbStack${NC}..."
    open -a OrbStack >/dev/null 2>&1
}

wait_for_docker_daemon() {
    local timeout="${1:-$C0_DOCKER_START_TIMEOUT}"
    local deadline=$((SECONDS + timeout))

    while (( SECONDS < deadline )); do
        if docker info >/dev/null 2>&1; then
            return 0
        fi
        sleep 2
    done
    docker info >/dev/null 2>&1
}

ensure_docker_daemon() {
    if ! command -v docker &>/dev/null; then
        echo "error: docker CLI not found in PATH" >&2
        return 1
    fi

    if docker info >/dev/null 2>&1; then
        return 0
    fi

    local endpoint
    endpoint="$(docker_endpoint_hint)"

    if maybe_start_orbstack; then
        if wait_for_docker_daemon "$C0_DOCKER_START_TIMEOUT"; then
            echo -e "🐳 Docker: ${GREEN}ready${NC}"
            return 0
        fi
        echo "error: Docker daemon did not become ready within ${C0_DOCKER_START_TIMEOUT}s" >&2
    else
        echo "error: Docker daemon unavailable" >&2
    fi

    if [[ -n "$endpoint" ]]; then
        echo "  endpoint: $endpoint" >&2
    fi
    if [[ "$endpoint" == *orbstack* || "$endpoint" == *OrbStack* ]]; then
        echo "  hint: open OrbStack, or set C0_DOCKER_AUTOSTART=1 to let c0 start it" >&2
    else
        echo "  hint: start Docker/OrbStack, then retry" >&2
    fi
    return 1
}

# =============================================================================
# Tools volume and runtime identity helpers (Phase 1)
# =============================================================================

# Check if tools volume exists
tools_volume_exists() {
    docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null
}

# Execute shell command in tools volume using alpine container
tools_volume_sh() {
    c0_docker_run -v "$SHARED_TOOLS_VOLUME:/tools" alpine sh -c "$*"
}

# List running container IDs using the shared tools volume
list_running_container_ids_using_tools_volume() {
    docker ps -q --filter "volume=$SHARED_TOOLS_VOLUME" 2>/dev/null || true
}

# Get tools hash label from a container
get_tools_hash_label() {
    local container_id="$1"
    docker inspect "$container_id" --format '{{ index .Config.Labels "c0dev.tools_hash" }}' 2>/dev/null || true
}

# Get unique active hashes from running containers
get_active_hashes() {
    local -a hashes=()
    local container_id hash

    while IFS= read -r container_id; do
        [[ -z "$container_id" ]] && continue
        hash="$(get_tools_hash_label "$container_id")"
        [[ -n "$hash" ]] && hashes+=("$hash")
    done < <(list_running_container_ids_using_tools_volume)

    # Return unique hashes (sorted)
    if [[ ${#hashes[@]} -gt 0 ]]; then
        printf '%s\n' "${hashes[@]}" | sort -u
    fi
}

# =============================================================================
# Pin management helpers (Phase 2)
# =============================================================================

# Compute folder identity (sha256 of C0ROOT:C0_MODE)
compute_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 1
    fi
    echo -n "${C0ROOT}:${C0_MODE}" | shasum -a 256 | cut -c1-64
}

# Get pin path for a folder ID
pin_path_for_folder_id() {
    local folder_id="$1"
    echo "/tools/pins/${folder_id}.pin"
}

# Read pin for current folder (returns hash or empty)
read_pin_for_folder_id() {
    local folder_id="$1"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    if ! tools_volume_exists; then
        return 0
    fi

    local content
    content="$(tools_volume_sh "cat '$pin_path' 2>/dev/null || true")"
    if [[ -n "$content" ]]; then
        echo "$content" | grep '^hash=' | cut -d= -f2
    fi
}

# Write pin for current folder
write_pin_for_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local folder_id="$1"
    local hash="$2"
    local c0root="$3"
    local mode="$4"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    local updated_at
    updated_at="$(date +%s)"

    tools_volume_sh "
        mkdir -p /tools/pins
        cat > '$pin_path' <<EOF
hash=$hash
c0root=$c0root
mode=$mode
updated_at=$updated_at
EOF
    " >/dev/null
}

# Delete pin for current folder
delete_pin_for_folder_id() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    local folder_id="$1"
    local pin_path
    pin_path="$(pin_path_for_folder_id "$folder_id")"

    if ! tools_volume_exists; then
        return 0
    fi

    tools_volume_sh "rm -f '$pin_path'" >/dev/null 2>&1 || true
}

# List all pins (outputs: folder_id hash c0root on each line)
list_all_pins() {
    if ! tools_volume_exists; then
        return 0
    fi

    local pins_list
    pins_list="$(tools_volume_sh "ls /tools/pins/*.pin 2>/dev/null || true")"
    [[ -z "$pins_list" ]] && return 0

    local pin_file
    while IFS= read -r pin_file; do
        [[ -z "$pin_file" ]] && continue
        local folder_id
        folder_id="$(basename "$pin_file" .pin)"
        local content
        content="$(tools_volume_sh "cat '$pin_file' 2>/dev/null || true")"
        if [[ -n "$content" ]]; then
            local hash c0root
            hash="$(echo "$content" | grep '^hash=' | cut -d= -f2)"
            c0root="$(echo "$content" | grep '^c0root=' | cut -d= -f2-)"
            if [[ -n "$hash" && -n "$c0root" ]]; then
                echo "$folder_id $hash $c0root"
            fi
        fi
    done <<<"$pins_list"
}

# =============================================================================
# Garbage collection helpers (Phase 5)
# =============================================================================

# Clean up orphan pins (pins for folders deleted from disk)
cleanup_orphan_pins() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    local folder_id hash c0root
    while read -r folder_id hash c0root; do
        [[ -z "$folder_id" ]] && continue
        if [[ ! -d "$c0root" ]]; then
            # Folder deleted, remove orphan pin
            delete_pin_for_folder_id "$folder_id"
        fi
    done < <(list_all_pins)
}

# Get all pinned hashes (from valid pins only)
get_pinned_hashes() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    local -a hashes=()
    local folder_id hash c0root
    while read -r folder_id hash c0root; do
        [[ -z "$folder_id" ]] && continue
        if [[ -d "$c0root" ]]; then
            hashes+=("$hash")
        fi
    done < <(list_all_pins)

    # Return unique hashes (sorted)
    if [[ ${#hashes[@]} -gt 0 ]]; then
        printf '%s\n' "${hashes[@]}" | sort -u
    fi
}

# Garbage collect unprotected hash directories
gc_tools_hashes() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        return 0
    fi

    if ! tools_volume_exists; then
        return 0
    fi

    # First, clean up orphan pins
    cleanup_orphan_pins

    # Compute protected set: active ∪ pinned
    local active_hashes pinned_hashes
    active_hashes="$(get_active_hashes)"
    pinned_hashes="$(get_pinned_hashes)"

    local -a protected=()
    if [[ -n "$active_hashes" ]]; then
        while IFS= read -r hash; do
            [[ -n "$hash" ]] && protected+=("$hash")
        done <<<"$active_hashes"
    fi
    if [[ -n "$pinned_hashes" ]]; then
        while IFS= read -r hash; do
            [[ -n "$hash" ]] && protected+=("$hash")
        done <<<"$pinned_hashes"
    fi

    # Get unique protected hashes
    local protected_set
    if [[ ${#protected[@]} -gt 0 ]]; then
        protected_set="$(printf '%s\n' "${protected[@]}" | sort -u)"
    fi

    # List existing hash dirs in /tools/opt
    local hash_dirs
    hash_dirs="$(tools_volume_sh "ls -1 /tools/opt 2>/dev/null || true")"
    [[ -z "$hash_dirs" ]] && return 0

    local hash
    while IFS= read -r hash; do
        [[ -z "$hash" ]] && continue

        # Skip if not 64-hex hash
        if [[ ! "$hash" =~ ^[0-9a-f]{64}$ ]]; then
            continue
        fi

        # Skip if no completeness marker (weird/partial dir)
        if ! tools_volume_sh "test -f '/tools/opt/$hash/.c0dev-complete'" 2>/dev/null; then
            continue
        fi

        # Skip if protected (active or pinned)
        if [[ -n "$protected_set" ]] && echo "$protected_set" | grep -qx "$hash"; then
            continue
        fi

        # Not protected - remove it
        if tools_volume_sh "rm -rf '/tools/opt/$hash'" 2>/dev/null; then
            echo -e "  🗑️  GC: ${YELLOW}${hash:0:12}...${NC}"
        fi
    done <<<"$hash_dirs"
}

# =============================================================================
# Build: tools volume (transactional) with staged rebuild support (Phase 4)
# =============================================================================

# Promote staged .next build to final location (if safe)
maybe_promote_staged_next() {
    local hash="$1"
    local VOL="$SHARED_TOOLS_VOLUME"

    if ! tools_volume_exists; then
        return 0
    fi

    # Check if .next staging exists
    if ! tools_volume_sh "test -d '/tools/tmp/$hash.next'" 2>/dev/null; then
        return 0
    fi

    # Check if hash is still active
    local active_hashes
    active_hashes="$(get_active_hashes)"
    if echo "$active_hashes" | grep -qx "$hash"; then
        # Still active, cannot promote yet
        return 0
    fi

    # Safe to promote
    echo -e "  📥 Promoting staged build..."
    if tools_volume_sh "
        set -e
        mkdir -p /tools/opt
        rm -rf '/tools/opt/$hash.old'
        if [ -d '/tools/opt/$hash' ]; then
            mv '/tools/opt/$hash' '/tools/opt/$hash.old'
        fi
        mv '/tools/tmp/$hash.next' '/tools/opt/$hash'
        rm -rf '/tools/opt/$hash.old'
    " 2>/dev/null; then
        echo -e "  ✅ Promoted: ${GREEN}/tools/opt/${hash:0:12}...${NC}"
    else
        echo "warning: failed to promote staged build" >&2
    fi
}

build_tools_volume() {
    local force="${1:-false}"
    local nocache="${2:-}"
    local H="$DOCKERFILE_HASH"
    local VOL="$SHARED_TOOLS_VOLUME"
    local TAG="c0dev-tools-builder:$H"

    if ! verify_moby_seccomp_profile; then
        return 1
    fi

    # Try to promote any staged .next build for this hash (Phase 4)
    maybe_promote_staged_next "$H"

    # Check if rebuild needed
    if [[ "$force" != "true" ]] && tools_volume_valid; then
        echo -e "📦 Tools: ${GREEN}valid${NC}"
        return 0
    fi

    echo -e "📦 Tools: building..."

    # Clean up any leftover containers from previous/interrupted builds
    docker rm -f "$MAIN_SERVICE-tools-build" 2>/dev/null || true
    docker rm -f "$MAIN_SERVICE-tools" 2>/dev/null || true

    # Cleanup function for interrupts
    _build_cleanup() {
        echo -e "\n${RED}build interrupted${NC}" >&2
        docker rmi "$TAG" 2>/dev/null || true
        # Remove partial temp dir
        c0_docker_run -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        exit 130
    }
    trap _build_cleanup INT TERM

    # 1) Ensure volume exists
    docker volume create "$VOL" >/dev/null

    # 2) Build tools image (BuildKit builder is short-lived; service hardening is in compose at runtime)
    echo -e "  🔧 Building tools-builder stage..."
    export DOCKER_BUILDKIT=1
    local -a build_args=()
    [[ -n "$nocache" ]] && build_args+=("$nocache")
    if ! docker build "${build_args[@]}" --target tools-builder -t "$TAG" "$C0ROOT/docker"; then
        trap - INT TERM
        return 1
    fi

    # 3) Stream tarball from tools image into volume temp dir
    echo -e "  📤 Extracting to temp..."
    if ! (c0_docker_run "$TAG" sh -lc 'tar -C /home/dev -cf - .cargo .rustup .local' | \
        c0_docker_run -i -v "$VOL:/tools" alpine sh -c "
            set -e
            rm -rf '/tools/tmp/$H.partial'
            mkdir -p '/tools/tmp/$H.partial'
            tar -C '/tools/tmp/$H.partial' -xf -
        "); then
        trap - INT TERM
        c0_docker_run -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        return 1
    fi

    # 4) Write completeness marker
    echo -e "  ✓ Marking complete..."
    if ! c0_docker_run -v "$VOL:/tools" alpine touch "/tools/tmp/$H.partial/.c0dev-complete"; then
        trap - INT TERM
        c0_docker_run -v "$VOL:/tools" alpine rm -rf "/tools/tmp/$H.partial" 2>/dev/null || true
        return 1
    fi

    # 5) Check if hash is active - if so, stage instead of promoting (Phase 4)
    local active_hashes
    active_hashes="$(get_active_hashes)"
    local is_active=false
    if echo "$active_hashes" | grep -qx "$H"; then
        is_active=true
    fi

    if [[ "$is_active" == "true" && "$force" == "true" ]]; then
        # Stage to .next instead of promoting
        echo -e "  📦 Staging (hash is active)..."
        if ! c0_docker_run -v "$VOL:/tools" alpine sh -c "
            set -e
            mkdir -p /tools/tmp
            rm -rf '/tools/tmp/$H.next.old'
            if [ -d '/tools/tmp/$H.next' ]; then
                mv '/tools/tmp/$H.next' '/tools/tmp/$H.next.old'
            fi
            mv '/tools/tmp/$H.partial' '/tools/tmp/$H.next'
            rm -rf '/tools/tmp/$H.next.old'
        "; then
            trap - INT TERM
            return 1
        fi
        echo -e "  ⏸️  Staged: will promote after instances stop"
    else
        # Safe to promote directly
        echo -e "  📥 Promoting..."
        if ! c0_docker_run -v "$VOL:/tools" alpine sh -c "
            set -e
            mkdir -p /tools/opt
            rm -rf '/tools/opt/$H.old'
            if [ -d '/tools/opt/$H' ]; then
                mv '/tools/opt/$H' '/tools/opt/$H.old'
            fi
            mv '/tools/tmp/$H.partial' '/tools/opt/$H'
            rm -rf '/tools/opt/$H.old'
            rm -rf '/tools/tmp/$H.partial'
        "; then
            trap - INT TERM
            return 1
        fi
    fi

    # 6) Post-verify
    if ! c0_docker_run -v "$VOL:/tools:ro" alpine test -f "/tools/opt/$H/.c0dev-complete"; then
        echo "error: tools build failed - completeness marker missing" >&2
        trap - INT TERM
        return 1
    fi

    # Cleanup builder image
    docker rmi "$TAG" >/dev/null 2>&1 || true

    # Clear trap
    trap - INT TERM

    echo -e "  ✅ Tools: ${GREEN}complete${NC}"
}

# =============================================================================
# Commands
# =============================================================================

cmd_start() {
    require_host "start"

    resolve_c0_security_for_start "$@" || exit 1

    ensure_web_port

    if ! ensure_host_paths; then
        echo "error: fix missing paths before starting" >&2
        exit 1
    fi
    if ! ensure_docker_daemon; then
        exit 1
    fi
    if ! verify_moby_seccomp_profile; then
        echo "error: seccomp profile verification failed" >&2
        exit 1
    fi
    maybe_notify_seccomp_update_available || true

    # Check tools volume
    if ! tools_volume_valid; then
        echo "error: tools volume invalid or missing - run 'c0 build' first" >&2
            exit 1
        fi

    echo -e "🚀 Starting ${CYAN}$PROJECT_NAME${NC}..."
    if ! dc up -d; then
        echo "error: failed to start containers (port may already be in use)" >&2
        echo "hint: retry with a different port, e.g. C0DEV_WEB_PORT=3001 c0 start" >&2
        exit 1
    fi
    print_security_mode
    print_ssh_auth_mapping
    print_web_port_mapping
    echo -e "✅ Started: ${GREEN}$MAIN_SERVICE${NC}"
}

cmd_stop() {
    require_host "stop"
    if ! ensure_docker_daemon; then
        exit 1
    fi
    echo -e "🛑 Stopping ${CYAN}$PROJECT_NAME${NC}..."
    dc down
    echo -e "✅ Stopped"
}

cmd_restart() {
    require_host "restart"

    resolve_c0_security_for_start "$@" || exit 1

    ensure_web_port
    if ! ensure_host_paths; then
        echo "error: fix missing paths before starting" >&2
        exit 1
    fi
    if ! ensure_docker_daemon; then
        exit 1
    fi
    echo -e "🔄 Restarting ${CYAN}$PROJECT_NAME${NC}..."
    dc down

    # Validate before restart
    if ! verify_moby_seccomp_profile; then
        echo "error: seccomp profile verification failed" >&2
        exit 1
    fi
    maybe_notify_seccomp_update_available || true
    if ! tools_volume_valid; then
        echo "error: tools volume invalid - run 'c0 build' first" >&2
            exit 1
        fi

    if ! dc up -d; then
        echo "error: failed to restart containers (port may already be in use)" >&2
        echo "hint: retry with a different port, e.g. C0DEV_WEB_PORT=3001 c0 start" >&2
        exit 1
    fi
    print_security_mode
    print_ssh_auth_mapping
    print_web_port_mapping
    echo -e "✅ Restarted: ${GREEN}$MAIN_SERVICE${NC}"
}

cmd_logs() {
    require_host "logs"
    if ! ensure_docker_daemon; then
        exit 1
    fi
    local service="${1:-$MAIN_SERVICE}"
    dc logs -f "$service"
}

cmd_status() {
    require_host "status"

    if [[ -n "$C0_MODE" ]]; then
        echo -e "${BOLD}mode:${NC} $C0_MODE"
    fi
    echo ""

    # Port mapping (if container exists)
    echo -e "${BOLD}ports:${NC}"
    local mapped_port
    mapped_port="$(get_current_web_port || true)"
    if [[ -n "$mapped_port" ]]; then
        echo -e "  🌐 ${YELLOW}host:${mapped_port}${NC} -> ${YELLOW}guest:3000${NC}"
    else
        echo -e "  ${YELLOW}(none)${NC}"
    fi
    echo ""

    echo -e "${BOLD}security:${NC}"
    local running_security configured_security
    running_security="$(get_running_container_security_mode)"
    if [[ -n "$running_security" ]]; then
        echo -e "  🔒 ${YELLOW}${running_security}${NC} (running)"
        if [[ -n "${C0_SECURITY:-}" && "${C0_SECURITY}" != "$running_security" ]]; then
            echo -e "  ${YELLOW}note:${NC} shell C0_SECURITY=${C0_SECURITY} differs; use matching flag on restart"
        fi
    else
        ensure_c0_security_resolved || true
        configured_security="${C0_SECURITY:-permissive}"
        echo -e "  🔒 ${YELLOW}${configured_security}${NC} (next start; default permissive)"
    fi
    echo ""

    echo -e "${BOLD}ssh agent:${NC}"
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        resolve_ssh_auth_sock_bind_source
        if [[ -n "${C0_SSH_AUTH_SOCK_BIND_SOURCE:-}" ]]; then
            echo -e "  🔑 ${YELLOW}${C0_SSH_AUTH_SOCK_GUEST}${NC} ← ${C0_SSH_AUTH_SOCK_BIND_SOURCE} (gid ${C0_SSH_AUTH_SOCK_GID:-$C0_SSH_AUTH_SOCK_GID_DEFAULT})"
        else
            echo -e "  ${YELLOW}(host socket unavailable; see warning above)${NC}"
        fi
    else
        echo -e "  ${YELLOW}(disabled; set SSH_AUTH_SOCK before c0 start)${NC}"
    fi
    print_ssh_probe_line "host" "$(probe_host_ssh_agent)"
    local ssh_container_id
    ssh_container_id="$(dc ps -q "$MAIN_SERVICE" 2>/dev/null | head -1 || true)"
    if [[ -n "$ssh_container_id" ]]; then
        print_ssh_probe_line "container" "$(probe_container_ssh_agent)"
    else
        echo -e "  ${YELLOW}container:${NC} not running"
    fi
    echo ""

    # Container status
    echo -e "${BOLD}running containers:${NC}"
    local container_info
    container_info=$(dc ps --format "{{.Name}}: {{.State}}" 2>/dev/null | head -1)
    if [[ -n "$container_info" ]]; then
        if [[ "$container_info" =~ running ]]; then
            echo -e "  ${GREEN}$container_info${NC}"
        elif [[ "$container_info" =~ exited ]]; then
            echo -e "  ${RED}$container_info${NC}"
        else
            echo -e "  ${YELLOW}$container_info${NC}"
        fi
    else
        echo -e "  ${YELLOW}(none)${NC}"
    fi
    echo ""

    # Volume mappings
    echo -e "${BOLD}volumes:${NC}"
    _status_mapping() {
        local abs_host_path="$1"
        local container_path="$2"
        local type="$3"
        local display_path="$4"
        local ro="$5"

        local ro_flag=""
        [[ "$ro" == "ro" ]] && ro_flag=" ${MAGENTA}[ro]${NC}"

        local status="ok"
        if [[ "$type" == "host-dir" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                status="MISSING"
            elif [[ ! -d "$abs_host_path" ]]; then
                status="NOT-DIR"
            fi
        elif [[ "$type" == "host-file" && -n "$abs_host_path" ]]; then
            if [[ ! -e "$abs_host_path" ]]; then
                status="MISSING"
            elif [[ ! -f "$abs_host_path" ]]; then
                status="NOT-FILE"
            fi
        fi

        local type_color="$BLUE"
        [[ "$type" == "docker-volume" ]] && type_color="$MAGENTA"

        if [[ "$status" == "ok" ]]; then
            echo -e "  ${GREEN}✓${NC} ${type_color}[$type]${NC} ${CYAN}$display_path${NC} -> ${YELLOW}$container_path${NC}$ro_flag"
        else
            echo -e "  ${RED}✗${NC} ${type_color}[$type]${NC} ${CYAN}$display_path${NC} -> ${YELLOW}$container_path${NC} ${RED}($status)${NC}"
        fi
    }

    parse_folder_mappings _status_mapping
    parse_file_mappings _status_mapping
    echo ""

    # Workspaces (grouped by tools hash)
    echo -e "${BOLD}workspaces:${NC}"
    if tools_volume_exists; then
        local pins_list
        pins_list="$(list_all_pins)"
        if [[ -n "$pins_list" ]]; then
            local current_folder_id
            current_folder_id="$(compute_folder_id 2>/dev/null || true)"

            # Get unique hashes
            local unique_hashes
            unique_hashes="$(echo "$pins_list" | awk '{print $2}' | sort -u)"

            # Display each hash group
            while IFS= read -r hash; do
                [[ -z "$hash" ]] && continue
                echo -e "  📦 ${YELLOW}${hash:0:12}...${NC}"

                # Display workspaces for this hash
                while IFS=' ' read -r folder_id pin_hash c0root; do
                    [[ "$pin_hash" != "$hash" ]] && continue
                    [[ -z "$c0root" ]] && continue

                    # Compute project name for this workspace
                    local ws_mode=""
                    if [[ "$folder_id" == *":dev" ]]; then
                        ws_mode="dev"
                    fi
                    local ws_project_name
                    if [[ "$ws_mode" == "dev" ]]; then
                        ws_project_name="c0dev-dev-$(short_hash "${c0root}:dev")"
                    else
                        ws_project_name="c0dev-$(short_hash "$c0root")"
                    fi

                    # Check if running and get port
                    local container_name="${ws_project_name}-${MAIN_SERVICE}"
                    local is_running=false
                    local port_info=""
                    if docker ps --format "{{.Names}}" 2>/dev/null | grep -qF "$container_name"; then
                        is_running=true
                        local port
                        port=$(docker ps --filter "name=$container_name" --format "{{.Ports}}" 2>/dev/null | sed -n 's/.*0\.0\.0\.0:\([0-9]*\).*/\1/p' | head -1)
                        [[ -n "$port" ]] && port_info=", :$port"
                    fi

                    # Build status indicators
                    local indicators=""
                    if [[ "$is_running" == "true" ]]; then
                        indicators="${GREEN}⚡${NC} "
                    else
                        indicators="   "
                    fi
                    if [[ -n "$current_folder_id" && "$folder_id" == "$current_folder_id" ]]; then
                        indicators+="${BOLD}*${NC} "
                    else
                        indicators+="  "
                    fi

                    echo -e "    $indicators${CYAN}$c0root${NC} ${YELLOW}($container_name$port_info)${NC}"
                done <<<"$pins_list"
            done <<<"$unique_hashes"
        else
            echo -e "  ${YELLOW}(none)${NC}"
        fi
    else
        echo -e "  ${YELLOW}(none)${NC}"
    fi
}

cmd_sh() {
    require_host "sh"
    if ! ensure_docker_daemon; then
        exit 1
    fi
    local project_path
    project_path=$(get_project_path)
    if [[ -n "$project_path" ]]; then
        local container_project_dir quoted_project_dir
        container_project_dir="$CONTAINER_DEV_HOME/projects/$project_path"
        printf -v quoted_project_dir '%q' "$container_project_dir"
        print_web_port_mapping
        echo -e "🐚 Shell: ${CYAN}$MAIN_SERVICE${NC} (dev) @ ${YELLOW}projects/$project_path${NC}"
        dc exec -u 1000 "$MAIN_SERVICE" bash -lc "cd -- $quoted_project_dir && exec bash -l"
    else
        print_web_port_mapping
        echo -e "🐚 Shell: ${CYAN}$MAIN_SERVICE${NC} (dev)"
        dc exec -u 1000 "$MAIN_SERVICE" bash -l
    fi
}

cmd_root() {
    require_host "root"
    if ! ensure_docker_daemon; then
        exit 1
    fi
    local project_path
    project_path=$(get_project_path)
    if [[ -n "$project_path" ]]; then
        local container_project_dir quoted_project_dir
        container_project_dir="$CONTAINER_DEV_HOME/projects/$project_path"
        printf -v quoted_project_dir '%q' "$container_project_dir"
        print_web_port_mapping
        echo -e "🔧 Shell: ${CYAN}$MAIN_SERVICE${NC} (${RED}root${NC}) @ ${YELLOW}projects/$project_path${NC}"
        dc exec -u 0 "$MAIN_SERVICE" bash -lc "cd -- $quoted_project_dir && exec bash"
    else
        print_web_port_mapping
        echo -e "🔧 Shell: ${CYAN}$MAIN_SERVICE${NC} (${RED}root${NC})"
        dc exec -u 0 "$MAIN_SERVICE" bash
    fi
}

cmd_cp_term() {
    require_host "cp-term"
    if ! ensure_docker_daemon; then
        exit 1
    fi
    local container_name
    container_name=$(dc ps -q "$MAIN_SERVICE" 2>/dev/null)
    if [[ -z "$container_name" ]]; then
        echo "error: container not running" >&2
            exit 1
        fi
        for term in xterm-256color $TERM; do
        infocmp -xa "$term" | docker exec -u 0 -i "$container_name" tic -x -o /usr/share/terminfo/ -
        echo -e "✅ Copied: ${CYAN}$term${NC}"
    done
}

cmd_build() {
    require_host "build"

    local force=false
    local nocache=""
    if [[ "$1" == "-f" || "$1" == "--force" ]]; then
        force=true
        nocache="--no-cache"
        echo -e "🔨 ${YELLOW}Force rebuild${NC} requested"
    fi

    if ! ensure_host_paths; then
        echo "error: fix missing paths before building" >&2
            exit 1
        fi
    if ! ensure_docker_daemon; then
        exit 1
    fi
    if ! verify_moby_seccomp_profile; then
        echo "error: seccomp profile verification failed" >&2
        exit 1
    fi
    maybe_notify_seccomp_update_available || true

    # Build/validate tools volume (has its own trap)
    if ! build_tools_volume "$force" "$nocache"; then
        echo "error: tools build failed" >&2
        exit 1
    fi

    # Trap for image build phase
    trap 'echo -e "\n${RED}build interrupted${NC}" >&2; exit 130' INT TERM

    # Prepare terminfo
    echo -e "📄 Preparing terminfo..."
    mkdir -p "$C0ROOT/docker/.terminfo"
    for term in xterm-256color $TERM; do
        infocmp -xa "$term" > "$C0ROOT/docker/.terminfo/$term" 2>/dev/null || true
    done

    # Build service image
    echo -e "🏗️  Building service image..."
    export DOCKER_BUILDKIT=1
    local -a build_args=()
    [[ -n "$nocache" ]] && build_args+=("$nocache")
    if ! dc build "${build_args[@]}" "$MAIN_SERVICE"; then
        echo "error: image build failed" >&2
        exit 1
    fi

    trap - INT TERM

    # Update pin on successful build (Phase 3)
    if [[ "$IN_CONTAINER" == "false" ]]; then
        local folder_id
        folder_id="$(compute_folder_id)"
        if [[ -n "$folder_id" ]]; then
            write_pin_for_folder_id "$folder_id" "$DOCKERFILE_HASH" "$C0ROOT" "$C0_MODE"
        fi
    fi

    # Run garbage collection after successful build (Phase 5)
    gc_tools_hashes

    echo -e "✅ ${GREEN}Build complete${NC}"
}

cmd_clean() {
    require_host "clean"
    if ! ensure_docker_daemon; then
        exit 1
    fi

    # Try to promote any staged .next build for current hash (Phase 4)
    maybe_promote_staged_next "$DOCKERFILE_HASH"

    local clean_all=false
    if [[ "$1" == "--all" || "$1" == "-a" ]]; then
        clean_all=true
    fi

    if [[ "$clean_all" == "true" ]]; then
        # Remove entire volume
        local containers
        containers=$(docker ps -aq --filter "volume=$SHARED_TOOLS_VOLUME" 2>/dev/null | tr '\n' ' ')
        if [[ -n "$containers" ]]; then
            echo -e "🛑 Removing containers using volume..."
            # shellcheck disable=SC2086 # containers is a docker-produced ID list.
            docker rm -f $containers >/dev/null
        fi

        echo -e "🧹 Removing volume ${CYAN}$SHARED_TOOLS_VOLUME${NC}..."
        if docker volume rm "$SHARED_TOOLS_VOLUME" >/dev/null 2>&1; then
            echo -e "✅ Removed: ${GREEN}$SHARED_TOOLS_VOLUME${NC}"
        else
            if docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
                echo "error: failed to remove $SHARED_TOOLS_VOLUME (in use?)" >&2
                exit 1
            else
                echo -e "${YELLOW}$SHARED_TOOLS_VOLUME does not exist${NC}"
            fi
        fi
    else
        # Remove current + pinned hash folders and unpin (Phase 3)
        if ! docker volume inspect "$SHARED_TOOLS_VOLUME" &>/dev/null; then
            echo -e "${YELLOW}volume $SHARED_TOOLS_VOLUME does not exist${NC}"
            return 0
        fi

        local current_hash="$DOCKERFILE_HASH"
        local pinned_hash=""
        local folder_id
        folder_id="$(compute_folder_id)"
        if [[ -n "$folder_id" ]]; then
            pinned_hash="$(read_pin_for_folder_id "$folder_id")"
        fi

        # Collect unique hashes to remove
        local -a hashes_to_remove=("$current_hash")
        if [[ -n "$pinned_hash" && "$pinned_hash" != "$current_hash" ]]; then
            hashes_to_remove+=("$pinned_hash")
        fi

        echo -e "🧹 Cleaning tools for this folder..."
        for hash in "${hashes_to_remove[@]}"; do
            if tools_volume_sh "test -d '/tools/opt/$hash'" 2>/dev/null; then
                if tools_volume_sh "rm -rf '/tools/opt/$hash'" 2>/dev/null; then
                    echo -e "  ✅ Removed: ${GREEN}/tools/opt/${hash:0:12}...${NC}"
                else
                    echo "error: failed to remove /tools/opt/$hash" >&2
                    exit 1
                fi
            fi
        done

        # Delete pin file
        if [[ -n "$folder_id" ]]; then
            delete_pin_for_folder_id "$folder_id"
            echo -e "  ✅ Removed pin"
        fi

        # Run garbage collection after clean (Phase 5)
        gc_tools_hashes
    fi
}

cmd_doctor() {
    require_host "doctor"

    local fix=false
    local doctor_failed=false
    case "${1:-}" in
        --fix) fix=true ;;
        "") ;;
        *)
            echo "error: unknown option: $1 (try --fix)" >&2
            exit 1
            ;;
    esac

    echo -e "${BOLD}c0 doctor${NC}"
    echo ""

    echo -e "${BOLD}host paths:${NC}"
    if [[ "$fix" == true ]]; then
        if ensure_host_paths; then
            echo -e "  ${GREEN}ok${NC}"
        else
            exit 1
        fi
    elif validate_host_paths; then
        echo -e "  ${GREEN}ok${NC}"
    else
        echo -e "  ${YELLOW}run:${NC} c0 doctor --fix"
        doctor_failed=true
    fi
    echo ""

    echo -e "${BOLD}docker:${NC}"
    if ensure_docker_daemon; then
        echo -e "  ${GREEN}ok${NC}"
    else
        exit 1
    fi
    echo ""

    echo -e "${BOLD}ssh agent:${NC}"
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        resolve_ssh_auth_sock_bind_source
        if [[ -n "${C0_SSH_AUTH_SOCK_BIND_SOURCE:-}" ]]; then
            echo -e "  🔑 ${YELLOW}${C0_SSH_AUTH_SOCK_GUEST}${NC} ← ${C0_SSH_AUTH_SOCK_BIND_SOURCE} (gid ${C0_SSH_AUTH_SOCK_GID:-$C0_SSH_AUTH_SOCK_GID_DEFAULT})"
        else
            echo -e "  ${YELLOW}(host socket unavailable; see warning above)${NC}"
        fi
    else
        echo -e "  ${YELLOW}(disabled; set SSH_AUTH_SOCK before c0 start)${NC}"
    fi
    local host_ssh_probe
    host_ssh_probe="$(probe_host_ssh_agent)"
    print_ssh_probe_line "host" "$host_ssh_probe"
    if [[ -n "${SSH_AUTH_SOCK:-}" ]] && ssh_probe_failed "$host_ssh_probe"; then
        doctor_failed=true
    fi
    local ssh_container_id
    ssh_container_id="$(dc ps -q "$MAIN_SERVICE" 2>/dev/null | head -1 || true)"
    if [[ -n "$ssh_container_id" ]]; then
        local container_ssh_probe
        container_ssh_probe="$(probe_container_ssh_agent)"
        print_ssh_probe_line "container" "$container_ssh_probe"
        if ssh_probe_failed "$container_ssh_probe"; then
            echo -e "  ${YELLOW}hint:${NC} rebuild with c0 build -f, restart, then re-run c0 doctor"
            doctor_failed=true
        fi
    else
        echo -e "  ${YELLOW}container:${NC} not running"
    fi
    echo ""

    echo -e "${BOLD}seccomp:${NC}"
    if verify_moby_seccomp_profile; then
        echo -e "  ${GREEN}ok${NC}"
    else
        exit 1
    fi
    echo ""

    echo -e "${BOLD}tools:${NC}"
    if tools_volume_valid; then
        echo -e "  ${GREEN}valid${NC}"
    else
        echo -e "  ${YELLOW}missing or stale${NC}; run c0 build"
    fi

    if [[ "$doctor_failed" == true ]]; then
        exit 1
    fi
}

cmd_help() {
    if [[ "$IN_CONTAINER" == "true" ]]; then
        cat <<EOF
Usage: c0 {help}

Commands (inside container):
  help          Show this help message

Note: Running inside container. Use 'exit' to return to host.
EOF
    else
        cat <<EOF
Usage: c0 {start|stop|restart|logs|status|sh|root|cp-term|build|clean|doctor|seccomp-upgrade|help}

Commands:
  start [--cap-drop-all]
                Start all services (default security: permissive)
  stop          Stop all services
  restart [--cap-drop-all]
                Restart all services
  logs [svc]    Show logs (default: $MAIN_SERVICE)
  status        Show service status, volume mappings, and workspaces
  sh            Shell as dev user (uid 1000)
  root          Shell as root (uid 0)
  cp-term       Copy terminfo into container
  build [-f]    Build tools and image (-f forces rebuild)
                Pins current Dockerfile hash on success for this folder.
                Triggers automatic cleanup of unpinned/inactive hashes.
  doctor [--fix]
                Check onboarding preconditions. --fix creates missing host dirs.
  seccomp-upgrade [--dry-run]
                Use git ls-remote on moby/profiles, pick latest seccomp/vM.m.p tag,
                curl raw default.json, verify sha256, then rewrite docker/seccomp when newer.
                --dry-run shows target tag, peeled commit OID, profile sha256; no writes.
  clean [-a]    Remove tools for current + pinned hashes; unpins this folder.
                Runs garbage collection. (-a removes entire shared volume)
  help          Show this help message

Environment:
  C0_MODE       Set to 'dev' for dev mode (default: production)
  C0_SECURITY   permissive (default) or cap-drop-all; overridden by start --cap-drop-all
  C0_SECCOMP_NOTIFY=0  Skip upstream seccomp "newer available" notices on build/start
  C0_SECCOMP_REMOTE_CACHE_TTL  Seconds to cache git ls-remote + profile hash (default 21600)
  C0_DOCKER_AUTOSTART=0  Disable macOS OrbStack autostart when Docker is unavailable
  C0_DOCKER_START_TIMEOUT  Seconds to wait after autostart (default 60)
  MOBY_PROFILES_GIT_URL  Override moby/profiles.git URL (default https://github.com/moby/profiles.git)

Notes:
  - Each folder pins its latest successful build hash
  - Active hashes (from running containers) are never garbage collected
  - Force rebuild of active hash stages to .next, promotes after stop
  - Ephemeral docker runs during build use --cap-drop ALL and no-new-privileges
  - Default start: permissive (cap_drop ALL + CHOWN/SETUID/SETGID for apt as root)
  - Strict Codex: c0 start --cap-drop-all or C0_SECURITY=cap-drop-all
  - Moby seccomp updates: notices on build/start if upstream tag is newer; run seccomp-upgrade to apply
  - SSH agent: set SSH_AUTH_SOCK in your shell before c0 start (no extra c0 env vars)
EOF
    fi
}

# =============================================================================
# Main
# =============================================================================

case "${1:-}" in
    start)      shift; cmd_start "$@" ;;
    stop)       cmd_stop ;;
    restart)    shift; cmd_restart "$@" ;;
    logs)       shift; cmd_logs "$@" ;;
    status)     cmd_status ;;
    sh)         cmd_sh ;;
    root)       cmd_root ;;
    cp-term)    cmd_cp_term ;;
    build)      shift; cmd_build "$@" ;;
    clean)      shift; cmd_clean "$@" ;;
    doctor)     shift; cmd_doctor "$@" ;;
    seccomp-upgrade) shift; cmd_seccomp_upgrade "$@" ;;
    help|--help|-h)
                cmd_help ;;
    *)
        if [[ "$IN_CONTAINER" == "false" ]]; then
            cmd_status
            echo ""
        fi
        cmd_help
        ;;
esac
